---
// AIMMA Storefront · /p/[slug] · Fase F (F1) · PDP real ×4 · 2026-06-09
// Data layer + dispatcher. Resuelve producto (con producto_variantes) + relacionados (misma categoria,
// tenant-scoped, excluye el actual) + serializa variantes para el selector cliente -> <ProductDetail>.
// La UI ×4 + selector + add-to-cart viven en los componentes; aca solo datos. /p es ruta VIVA.

import Layout from '~/layouts/Layout.astro';
import ProductDetail from '~/components/ProductDetail.astro';
import { getProductoPorSlug, getProductosPorTienda } from '~/lib/catalogo';

const { tienda, supabase } = Astro.locals;
const { slug } = Astro.params;

if (!slug) return Astro.redirect('/', 302);

const producto: any = await getProductoPorSlug(supabase, tienda.id, slug);

if (!producto) {
  return new Response(
    `<!DOCTYPE html><html lang="es"><head><meta charset="UTF-8" /><title>Producto no encontrado</title></head><body><h1>Producto no encontrado</h1><p><a href="/">Volver al inicio</a></p></body></html>`,
    { status: 404, headers: { 'Content-Type': 'text/html; charset=utf-8' } }
  );
}

// ── Precio base + galeria ──
const precioBase = Number(producto.precio_promo ?? producto.precio_venta ?? 0);
const precioAnterior = producto.precio_promo && producto.precio_promo < (producto.precio_venta || 0)
  ? Number(producto.precio_venta) : null;

const galeria: string[] = [
  producto.foto_principal_url,
  ...((Array.isArray(producto.fotos_galeria) ? producto.fotos_galeria : []) as string[]),
].filter(Boolean);

// ── Variantes (modelo: ejes variante_tipo_1/2; filas color/talla/stock/reservado/foto_color_url/precio_override) ──
const variantesRaw = Array.isArray(producto.producto_variantes) ? producto.producto_variantes : [];
// disponible = stock - reservado (LECTURA, no toca la reserva — esa vive en el checkout/EF).
const variantes = variantesRaw.map((v: any) => ({
  id: v.id,
  color: v.color ?? null,
  talla: v.talla ?? null,
  sku: v.sku ?? null,
  disponible: Math.max(0, (v.stock || 0) - (v.reservado || 0)),
  foto_color_url: v.foto_color_url ?? null,
  precio: Number(v.precio_override ?? producto.precio_promo ?? producto.precio_venta ?? 0),
}));
const stockTotal = variantes.reduce((acc: number, v: any) => acc + v.disponible, 0);
const tieneVariantes = variantes.length > 0;
const sinStock = tieneVariantes && stockTotal === 0;

// ── Relacionados: misma categoria, tenant-scoped, excluye el actual ──
let relacionados: Awaited<ReturnType<typeof getProductosPorTienda>> = [];
if (producto.categoria_id) {
  try {
    const r = await getProductosPorTienda(supabase, tienda.id, { categoriaId: producto.categoria_id, limit: 9 });
    relacionados = r.filter((p) => p.id !== producto.id).slice(0, 8);
  } catch (err) {
    console.error('[pdp] relacionados', err);
    relacionados = [];
  }
}

const precioCOP = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0, maximumFractionDigits: 0 });

// WhatsApp (atajo "comprar ya" del producto base; el selector arma el de la variante elegida en cliente)
const wppDigits = (tienda.whatsapp_dueno || '').replace(/\D/g, '');

// JSON-LD Product (igual que antes)
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'Product', name: producto.nombre,
  ...(producto.descripcion && { description: producto.descripcion }),
  ...(galeria.length > 0 && { image: galeria }),
  ...(producto.referencia && { sku: producto.referencia }),
  brand: { '@type': 'Brand', name: tienda.nombre_negocio },
  offers: {
    '@type': 'Offer', price: precioBase, priceCurrency: 'COP',
    availability: sinStock ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    url: Astro.url.toString(),
  },
};

// Props para el dispatcher / componentes ×4
const pdp = {
  producto, galeria, variantes, tieneVariantes, stockTotal, sinStock,
  precioBase, precioAnterior,
  precioBaseFmt: precioCOP.format(precioBase),
  precioAnteriorFmt: precioAnterior != null ? precioCOP.format(precioAnterior) : null,
  variante_tipo_1: producto.variante_tipo_1 ?? null,
  variante_tipo_2: producto.variante_tipo_2 ?? null,
  relacionados,
  wppDigits,
  tiendaNombre: tienda.nombre_negocio,
  productUrl: Astro.url.toString(),
};
---

<Layout
  title={producto.nombre}
  description={producto.descripcion?.slice(0, 200) || `Compra ${producto.nombre} en ${tienda.nombre_negocio}.`}
  ogImage={producto.foto_principal_url || undefined}
  jsonLd={jsonLd}
>
  <ProductDetail pdp={pdp} />
</Layout>
