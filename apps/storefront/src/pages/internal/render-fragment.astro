---
// AIMMA Fase C — render-fragment (GET page): renderiza UNA seccion via BlockRenderer por el
// page-render path (el unico que anda en workerd; Container API crashea). La seccion viene del KV
// stash (nonce). token-gated (autoridad unica), tienda PURAMENTE del token (A1), sanitize FUENTE
// UNICA (== save) ANTES de render, supabase ANON+RLS (mismo scope que pagina publica).
// Output: <!DOCTYPE html><link><script> + <section data-section-id> -> el admin extrae el nodo (DOMParser).
import BlockRenderer from '~/components/BlockRenderer.astro';
import { getSupabase } from '~/lib/supabase';
import { validateAndSanitizeSection } from '@aimma/database';

export const prerender = false;
// CORS: el admin (aimma.com.co) fetchea esta pagina cross-origin. GET simple -> sin preflight, pero
// la respuesta necesita Access-Control-Allow-Origin para que el JS del admin pueda leerla.
const NO_STORE = { 'Cache-Control': 'no-store', 'Access-Control-Allow-Origin': 'https://aimma.com.co' };

const token = Astro.url.searchParams.get('preview');
if (!token) return new Response('forbidden', { status: 403, headers: NO_STORE });
const supabase = getSupabase(); // ANON + RLS
const { data: tiendaId, error } = await supabase.rpc('validate_preview_token', { p_token: token });
if (error || !tiendaId) return new Response('forbidden', { status: 403, headers: NO_STORE });

const nonce = Astro.url.searchParams.get('nonce');
if (!nonce) return new Response('bad request', { status: 400, headers: NO_STORE });
const kv: any = (Astro.locals as any).runtime?.env?.TENANT_CACHE;
const raw = kv ? await kv.get('frag:' + nonce) : null;
if (!raw) return new Response('KV_MISS', { status: 404, headers: NO_STORE });
let parsed: any;
try { parsed = JSON.parse(raw); } catch { return new Response('bad request', { status: 400, headers: NO_STORE }); }
// scope: el nonce debe pertenecer a la tienda del token (otra sesion no lee tu fragmento).
if (parsed.tienda_id !== tiendaId) return new Response('forbidden', { status: 403, headers: NO_STORE });

// tienda PURAMENTE del token (A1). anon RLS -> no accede a mas data que la pagina publica.
const { data: tienda } = await supabase
  .from('tiendas').select('*, plantilla:plantillas(*), paleta:paletas(*)').eq('id', tiendaId).single();
if (!tienda) return new Response('not found', { status: 404, headers: NO_STORE });

// sanitize FUENTE UNICA (== save) ANTES de renderizar.
let section: any;
try { section = validateAndSanitizeSection(parsed.section); } catch { return new Response('bad request', { status: 400, headers: NO_STORE }); }

// locals para el render: anon+RLS, mismo scope que la pagina publica.
(Astro.locals as any).tienda = tienda;
(Astro.locals as any).supabase = supabase;
(Astro.locals as any).tiendaSlug = (tienda as any).slug;
// C.2 Paso 2: render-fragment ES preview -> el nodo patcheado emite data-field IDENTICO al render inicial.
(Astro.locals as any).isPreview = true;
Astro.response.headers.set('Cache-Control', 'no-store');
Astro.response.headers.set('Access-Control-Allow-Origin', 'https://aimma.com.co');
---
<BlockRenderer sections={[section]} />
