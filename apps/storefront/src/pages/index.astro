---
// AIMMA Storefront · / (home) · v3 · 2026-06-02
// BlockRenderer (schema v3) si hay pages.home; else fallback Hero+ProductGrid.
// Modo preview (?preview=<token>): valida token efimero, renderiza pages.home_draft
// fresco (bypass cache), noindex, e inyecta puente postMessage para el Editor PRO-MAX.

import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/Hero.astro';
import ProductGrid from '~/components/ProductGrid.astro';
import BlockRenderer from '~/components/BlockRenderer.astro';
import PreviewChrome from '~/components/PreviewChrome.astro';
import InlineEdit from '~/components/InlineEdit.astro';
import { getProductosPorTienda } from '~/lib/catalogo';
import { parsePersonalizaciones, FONT_PAIRINGS, CSS_COLOR_REGEX } from '@aimma/database';

const { tienda, supabase } = Astro.locals;
const plantillaSlug = tienda.plantilla?.slug;

const ADMIN_ORIGIN = 'https://aimma.com.co';
const previewToken = Astro.url.searchParams.get('preview');
let isPreview = false;

// ── Modo preview: validar token efimero + leer draft fresco (sin cache KV) ──
let persRaw: unknown = tienda.personalizaciones;
if (previewToken) {
  // RLS de preview_tokens esta cerrada; validamos via RPC SECURITY DEFINER
  // (anon solo puede validar el token que ya posee, no listar la tabla).
  const { data: validTiendaId } = await supabase
    .rpc('validate_preview_token', { p_token: previewToken });

  const valido = validTiendaId && validTiendaId === tienda.id;
  if (!valido) {
    return new Response('Preview token invalido o expirado', {
      status: 403,
      headers: { 'Content-Type': 'text/plain; charset=utf-8' },
    });
  }
  isPreview = true;
  // Releer fresco de Postgres (el tenant de locals viene de KV, puede estar cacheado).
  const { data: fresh } = await supabase
    .from('tiendas')
    .select('personalizaciones')
    .eq('id', tienda.id)
    .single();
  persRaw = fresh?.personalizaciones ?? tienda.personalizaciones;
}

// C.2 Paso 2: los renderers emiten data-field SOLO en preview (publico sin marcadores).
Astro.locals.isPreview = isPreview;

const pers = parsePersonalizaciones(persRaw);
// En preview priorizar home_draft; en publico, home.
const homeSections =
  (isPreview ? (pers?.pages?.home_draft?.sections ?? pers?.pages?.home?.sections)
             : pers?.pages?.home?.sections) ?? null;

// Solo cargar productos para fallback (los blocks cargan sus propios productos).
let productos: Awaited<ReturnType<typeof getProductosPorTienda>> = [];
if (!homeSections) {
  productos = await getProductosPorTienda(supabase, tienda.id, { limit: 12 });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: tienda.nombre_negocio,
  ...(tienda.email_contacto && { email: tienda.email_contacto }),
  ...(tienda.telefono_contacto && { telephone: tienda.telefono_contacto }),
  ...(tienda.direccion && {
    address: {
      '@type': 'PostalAddress',
      streetAddress: tienda.direccion,
      ...(tienda.ciudad_negocio && { addressLocality: tienda.ciudad_negocio }),
      addressCountry: 'CO',
    },
  }),
  url: Astro.url.toString(),
  ...(tienda.logo_url && { logo: tienda.logo_url, image: tienda.logo_url }),
};
---

<Layout
  title={undefined}
  description={`Compra en ${tienda.nombre_negocio}. Tienda online con envios a Colombia. Pedidos faciles por WhatsApp.`}
  jsonLd={jsonLd}
  noindex={isPreview}
  isPreview={isPreview}
>
  {homeSections ? (
    <BlockRenderer sections={homeSections} />
  ) : (
    <>
      <Hero />

      {plantillaSlug === 'fashion_bold' && (
    <section id="productos" class="pt-20 lg:pt-28 pb-24 lg:pb-32 px-6 md:px-12 lg:px-20">
      <header class="mb-10 lg:mb-14 flex items-end justify-between gap-6 border-b border-[var(--ta-color-text-base)] pb-4">
        <h2 class="font-display uppercase leading-none tracking-[-0.04em] text-[var(--ta-color-text-base)]" style="font-size:clamp(2rem, 5vw, 3.5rem);">
          Coleccion
        </h2>
        <p class="font-body text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65 hidden sm:block">
          {productos.length} piezas
        </p>
      </header>
      <ProductGrid productos={productos} />
    </section>
  )}

  {plantillaSlug === 'minimal_artesanal' && (
    <section id="productos" class="pt-28 lg:pt-40 pb-32 lg:pb-48 px-8 lg:px-16 mx-auto max-w-screen-2xl">
      <header class="mb-16 lg:mb-24 text-center">
        <p class="font-display italic text-[var(--ta-color-text-base)]/55 mb-3" style="font-size:0.95rem; font-variation-settings:'opsz' 24;">
          La coleccion
        </p>
        <h2 class="font-display text-[var(--ta-color-text-base)]" style="font-size:clamp(2rem, 4.5vw, 3.5rem); font-weight:400; letter-spacing:-0.02em; font-variation-settings:'opsz' 96;">
          Piezas en edicion
        </h2>
      </header>
      <ProductGrid productos={productos} />
    </section>
  )}

  {plantillaSlug === 'editorial_magazine' && (
    <section id="productos" class="pt-24 lg:pt-36 pb-28 lg:pb-40">
      <header class="mb-12 lg:mb-20">
        <div class="flex items-baseline gap-4 mb-6">
          <span class="block h-px w-12 bg-[var(--ta-color-accent)]"></span>
          <p class="font-body text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-accent)] font-medium">
            Edicion en curso
          </p>
        </div>
        <h2 class="font-display text-[var(--ta-color-text-base)]" style="font-size:clamp(2.25rem, 5.5vw, 4.5rem); font-weight:300; line-height:1; letter-spacing:-0.01em;">
          La <span class="italic" style="color:var(--ta-color-accent);">coleccion</span> impresa
        </h2>
        <p class="mt-6 max-w-[55ch] font-display italic text-[var(--ta-color-text-base)]/70" style="font-size:1.1rem; line-height:1.4;">
          Piezas seleccionadas pieza por pieza, presentadas como tal.
        </p>
      </header>
      <ProductGrid productos={productos} />
    </section>
  )}

  {(plantillaSlug === 'industrial_clean' || !plantillaSlug || !['fashion_bold', 'minimal_artesanal', 'editorial_magazine'].includes(plantillaSlug)) && (
    <section id="productos" class="py-12 lg:py-16">
      <header class="mb-8 flex items-end justify-between">
        <div>
          <h2 class="font-display text-[var(--ta-color-text-base)]" style="font-size:1.85rem; font-weight:600; letter-spacing:-0.028em;">
            Catalogo
          </h2>
          <p class="mt-1 font-body text-[13px] text-[var(--ta-color-text-base)]/60 tabular-nums">
            {productos.length} referencias activas
          </p>
        </div>
      </header>
      <ProductGrid productos={productos} />
    </section>
  )}
    </>
  )}
</Layout>

{isPreview && (
  <script is:inline define:vars={{ ADMIN_ORIGIN, PAIRINGS: FONT_PAIRINGS, COLOR_RE: CSS_COLOR_REGEX.source }}>
    // Puente Editor PRO-MAX (solo en preview). Click en seccion -> avisa al panel.
    // Recibe {type:'reload'} -> recarga. Valida origin en ambos sentidos.
    document.addEventListener('click', (e) => {
      if (!(e.target instanceof Element)) return;
      // Clicks del chrome de seleccion: los maneja PreviewChrome, no seleccionar/deseleccionar.
      if (e.target.closest('[data-ed-chrome]')) return;
      const el = e.target.closest('[data-section-id]');
      if (el) {
        e.preventDefault();
        const sectionId = el.getAttribute('data-section-id');
        try { parent.postMessage({ type: 'select', sectionId }, ADMIN_ORIGIN); } catch (_) {}
      } else {
        // Click en espacio vacio del canvas -> deseleccion (el admin nuevo hara set-selection(null)).
        try { parent.postMessage({ type: 'select', sectionId: null }, ADMIN_ORIGIN); } catch (_) {}
      }
    }, true);

    window.addEventListener('message', (e) => {
      if (e.origin !== ADMIN_ORIGIN) return;
      const msg = e.data || {};
      if (msg.type === 'reload') location.reload();
      if (msg.type === 'theme' && msg.colors && typeof msg.colors === 'object') {
        const re = new RegExp(COLOR_RE);
        for (const k in msg.colors) {
          const v = msg.colors[k];
          // Solo vars --ta-color-* con valor que pasa el MISMO regex que el Zod (preview == guardado).
          if (typeof k === 'string' && k.indexOf('--ta-color-') === 0 && typeof v === 'string' && re.test(v)) {
            document.documentElement.style.setProperty(k, v);
          }
        }
        // Fuente: SOLO el ID del allowlist; la url/family se DERIVAN server-side de PAIRINGS (nunca URL cruda).
        // hasOwnProperty: un id como 'constructor'/'__proto__' NO debe resolver a una cadena del prototipo.
        const p = (typeof msg.font_pairing === 'string' && Object.prototype.hasOwnProperty.call(PAIRINGS, msg.font_pairing)) ? PAIRINGS[msg.font_pairing] : null;
        if (p) {
          document.documentElement.style.setProperty('--ta-font-display', p.display);
          document.documentElement.style.setProperty('--ta-font-body', p.body);
          if (!document.querySelector('link[data-theme-font="' + msg.font_pairing + '"]')) {
            const l = document.createElement('link');
            l.rel = 'stylesheet'; l.href = p.url; l.setAttribute('data-theme-font', msg.font_pairing);
            document.head.appendChild(l);
          }
        }
      }
      if (msg.type === 'section-patch') {
        // Origin ya validado arriba (=== exacto). Shape ESTRICTO antes de tocar el DOM.
        const OPS = { replace: 1, insert: 1, remove: 1, move: 1 };
        if (!OPS[msg.op]) return;
        if (typeof msg.sectionId !== 'string' || !/^sec_[a-z0-9]{4,}$/.test(msg.sectionId)) return;
        const first = document.querySelector('[data-section-id]');
        const cont = first ? first.parentElement : null;
        const el = document.querySelector('[data-section-id="' + msg.sectionId + '"]');
        if (msg.op === 'remove') { if (el) el.remove(); return; }
        if (msg.op === 'move') {
          // splice semantics (== editorState.reorderSections): sacar el nodo PRIMERO y recien
          // insertar en toIndex sobre el array ya sin el. Sin el remove previo, insertBefore con
          // from<toIndex queda corrido (children[toIndex] cuenta a el todavia presente).
          if (el && cont && Number.isInteger(msg.toIndex)) {
            el.remove();
            cont.insertBefore(el, cont.children[msg.toIndex] || null);
          }
          return;
        }
        // replace/insert: el html es NUESTRO SSR (sanitizado por la fn compartida) + origin-gated.
        // SHAPE estricto del html ANTES del DOM: exactamente UN <section data-section-id=msg.sectionId>.
        // NO re-sanitiza (Q4.3); valida que sea EL nodo section esperado -> nunca corrompe el DOM con
        // html inesperado (caza render-bugs). Usa el nodo parseado (no outerHTML con string crudo).
        if (typeof msg.html !== 'string') return;
        const t = document.createElement('template');
        t.innerHTML = msg.html.trim();
        const node = t.content.children.length === 1 ? t.content.firstElementChild : null;
        if (!node || node.tagName !== 'SECTION' || node.getAttribute('data-section-id') !== msg.sectionId) return;
        if (msg.op === 'replace') { if (el) el.replaceWith(node); return; }
        if (msg.op === 'insert' && cont && Number.isInteger(msg.index)) {
          cont.insertBefore(node, cont.children[msg.index] || null);
        }
      }
    });

    // Avisar al panel que el preview esta listo.
    try { parent.postMessage({ type: 'preview-ready' }, ADMIN_ORIGIN); } catch (_) {}
  </script>
)}

{isPreview && <PreviewChrome />}
{isPreview && <InlineEdit />}
