---
// AIMMA Storefront · OptimizedImage.astro · 2026-05-31 (img-fix 2026-06-03)
// Wrapper de <img>. Por DEFAULT sirve la URL CRUDA de la imagen (sin transform).
//
// Cloudflare Image Resizing (/cdn-cgi/image/<options>/<source-url>) esta DESACTIVADO
// por default: requiere la feature habilitada en la zona Cloudflare (Pro+), que hoy NO
// lo esta -> esos paths dan 404 (imagenes rotas). Por eso el wrapper queda detras del
// flag CF_IMAGE_RESIZING (env, default false). Para reactivarlo:
//   1) habilitar Image Resizing en la zona aimma.com.co (Cloudflare dashboard), y
//   2) setear CF_IMAGE_RESIZING="true" (wrangler.toml [vars] o `wrangler secret put`).
// Con el flag ON: srcset responsive + format=auto (negocia WebP/AVIF). Con OFF: URL cruda.
// cfImage() es el UNICO lugar donde se construye la URL de imagen.

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'lazy' | 'eager';
  class?: string;
  sizes?: string;
  transitionName?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  class: className,
  sizes = '(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw',
  transitionName,
} = Astro.props;

// Cloudflare Image Resizing pattern. Solo aplica si las TRES condiciones:
//   1) flag CF_IMAGE_RESIZING="true" (la feature esta habilitada en la zona)
//   2) src es URL absoluta (http/https)
//   3) estamos en host bajo aimma.com.co (CF proxy activo)
const cfResizing = Astro.locals.runtime?.env?.CF_IMAGE_RESIZING === 'true';
const host = Astro.request.headers.get('host') || '';
const cfActive = cfResizing && host.endsWith('aimma.com.co');

function cfImage(srcUrl: string, w: number, quality = 85): string {
  if (!cfActive || !srcUrl.startsWith('http')) return srcUrl;
  const opts = `width=${w},format=auto,quality=${quality}`;
  return `/cdn-cgi/image/${opts}/${srcUrl}`;
}

// Responsive widths (escalas de imagen para srcset).
const widths = [Math.round(width * 0.5), width, Math.round(width * 1.5), width * 2];
const srcset = widths
  .map((w) => `${cfImage(src, w)} ${w}w`)
  .join(', ');

// Default src = base width
const defaultSrc = cfImage(src, width);

const styleAttr = transitionName ? `view-transition-name: ${transitionName}` : undefined;
---

<img
  src={defaultSrc}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  decoding={loading === 'eager' ? 'sync' : 'async'}
  class={className}
  style={styleAttr}
/>
