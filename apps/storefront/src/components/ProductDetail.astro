---
// AIMMA Storefront · ProductDetail.astro · Fase F (F1) · dispatcher ×4 (como Header/ProductGrid).
// Recibe el objeto `pdp` (datos ya resueltos en /p/[slug]) y despacha al PDP de la plantilla activa.
import ProductDetailIC from '~/components/templates/industrial_clean/ProductDetailIC.astro';
import ProductDetailFB from '~/components/templates/fashion_bold/ProductDetailFB.astro';
import ProductDetailMA from '~/components/templates/minimal_artesanal/ProductDetailMA.astro';
import ProductDetailEM from '~/components/templates/editorial_magazine/ProductDetailEM.astro';

interface Props { pdp: any }
const { pdp } = Astro.props;
const { tienda } = Astro.locals;
const slug = tienda.plantilla?.slug;
---

{slug === 'fashion_bold' && <ProductDetailFB pdp={pdp} />}
{slug === 'minimal_artesanal' && <ProductDetailMA pdp={pdp} />}
{slug === 'editorial_magazine' && <ProductDetailEM pdp={pdp} />}
{(slug === 'industrial_clean' || !slug || !['fashion_bold', 'minimal_artesanal', 'editorial_magazine'].includes(slug)) && (
  <ProductDetailIC pdp={pdp} />
)}
