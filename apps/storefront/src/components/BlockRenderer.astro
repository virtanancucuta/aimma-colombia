---
// AIMMA Editor PRO-MAX · BlockRenderer dispatcher · Fase D (D2)
// Mapea cada seccion top-level a <BlockOne> (el despacho UNIFIED/BLOCKS/pickBlock vive en
// _BlockOne.astro, extraido verbatim). El render por seccion es byte-identico al inline previo
// (guard: test/blockrenderer.golden ×4). El routing de `contenedor` -> Contenedor.astro se agrega
// en el commit siguiente, tras validar la byte-identidad de la extraccion.

import type { Section } from '@aimma/database';
import BlockOne from '~/components/blocks/_BlockOne.astro';

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

{sections.map((section) => <BlockOne section={section} />)}
