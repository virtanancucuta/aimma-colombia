---
// AIMMA Storefront · EditorCanvasDnD · Fase D A1 · DnD de hijos EN EL CANVAS (SOLO preview).
// Incluido en EditorPreviewBridge (que el padre emite SOLO con {isPreview && ...}) -> el render PUBLICO
// nunca lo emite (sin script, sin estilos globales). La logica vive en ~/lib/canvas-dnd (deps inyectadas,
// testeable); aca solo se cablea al document del iframe + window.Sortable (npm) + parent.postMessage.
---

<script>
  import Sortable from 'sortablejs';
  import { setupCanvasDnD, destroyCanvasDnD } from '~/lib/canvas-dnd';

  const ADMIN_ORIGIN = 'https://aimma.com.co';

  function run() {
    setupCanvasDnD({
      doc: document,
      getSortable: () => Sortable,
      postMove: (msg) => { try { parent.postMessage(msg, ADMIN_ORIGIN); } catch (_) { /* noop */ } },
    });
  }

  run();
  document.addEventListener('astro:page-load', run);

  // Tras el patch replace del contenedor (o reload), el bridge hace replaceWith -> el subarbol viejo
  // (grips + Sortables) se reemplaza. Re-armar DESPUES del replaceWith (setTimeout 0 = macrotask post
  // listener del bridge). destroyCanvasDnD() dentro de setup mata las instancias viejas (sin orphans).
  window.addEventListener('message', (e) => {
    if (e.origin !== ADMIN_ORIGIN) return;
    const t = e.data && e.data.type;
    if (t === 'section-patch' || t === 'reload') setTimeout(run, 0);
  });

  // Limpieza al navegar (View Transitions).
  document.addEventListener('astro:before-swap', destroyCanvasDnD);
</script>

<!-- El CSS del chrome (grip/ghost/clon/columna-destino) lo INYECTA canvas-dnd.ts en runtime (injectStyles)
     SOLO en preview, no via <style> de Astro: un <style> de un componente importado entra al bundle
     PUBLICO aunque el render sea {isPreview && ...}. Sin <style> aca -> render publico byte-identico. -->
