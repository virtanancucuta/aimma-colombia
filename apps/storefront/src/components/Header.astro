---
// AIMMA Storefront · Header.astro · v2 · 2026-05-31
// Dispatcher: resuelve la variante de header segun plantilla activa.
// Carga categorias top-level y las pasa a todos los variants.

import HeaderFB from '~/components/templates/fashion_bold/HeaderFB.astro';
import HeaderIC from '~/components/templates/industrial_clean/HeaderIC.astro';
import HeaderMA from '~/components/templates/minimal_artesanal/HeaderMA.astro';

const { tienda, supabase } = Astro.locals;
const slug = tienda.plantilla?.slug;

const { data: categorias } = await supabase
  .from('categorias')
  .select('id, nombre, slug, orden')
  .eq('tienda_id', tienda.id)
  .is('parent_id', null)
  .order('orden', { ascending: true })
  .limit(8);

const cats = categorias || [];
---

{slug === 'fashion_bold' && <HeaderFB tienda={tienda} categorias={cats} />}
{slug === 'minimal_artesanal' && <HeaderMA tienda={tienda} categorias={cats} />}
{(slug === 'industrial_clean' || !slug || (slug !== 'fashion_bold' && slug !== 'minimal_artesanal')) && (
  <HeaderIC tienda={tienda} categorias={cats} />
)}
