---
// AIMMA Storefront · Header.astro · 2026-05-31
// Header con logo + nav categorias top-level + carrito.

import CategoryNav from '~/components/CategoryNav.astro';

const { tienda, supabase } = Astro.locals;

// Categorias top-level (parent_id IS NULL) para el nav principal.
const { data: categorias } = await supabase
  .from('categorias')
  .select('id, nombre, slug, orden')
  .eq('tienda_id', tienda.id)
  .is('parent_id', null)
  .order('orden', { ascending: true })
  .limit(8); // top 8 visibles, resto en menu lateral
---

<header class="sticky top-0 z-30 border-b bg-[var(--ta-color-bg-base)]/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-3" aria-label={tienda.nombre_negocio}>
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt={tienda.nombre_negocio}
          width="40"
          height="40"
          class="h-10 w-10 rounded object-contain"
          loading="eager"
        />
      ) : (
        <span class="text-xl font-semibold text-[var(--ta-color-text-base)]">
          {tienda.nombre_negocio}
        </span>
      )}
      {tienda.logo_url && (
        <span class="hidden text-lg font-semibold text-[var(--ta-color-text-base)] sm:inline">
          {tienda.nombre_negocio}
        </span>
      )}
    </a>

    {categorias && categorias.length > 0 && (
      <CategoryNav categorias={categorias} />
    )}

    <div class="flex items-center gap-3">
      <a
        href="/carrito"
        class="rounded-md px-3 py-2 text-sm font-medium text-[var(--ta-color-text-base)] hover:bg-black/5"
        aria-label="Carrito"
      >
        <span class="inline-flex items-center gap-1.5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="hidden sm:inline">Carrito</span>
        </span>
      </a>
    </div>
  </div>
</header>
