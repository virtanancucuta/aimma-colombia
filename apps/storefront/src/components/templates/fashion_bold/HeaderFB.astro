---
// Fashion Bold · Header · 2026-05-31
// Streetwear / editorial. Logo wordmark display-font uppercase, nav uppercase
// tracking-wide, sticky con animation scroll-state. Edge-to-edge (no max-width).
// Spec del research: h-[60px] mobile / h-[72px] desktop. Underline animado bottom
// en hover (grueso 3px). NO color shift.

interface Tienda {
  nombre_negocio: string;
  logo_url: string | null;
}
interface Categoria {
  id: string;
  nombre: string;
  slug: string;
  orden: number;
}

import type { MenuItem } from '~/lib/menu';

interface Props {
  tienda: Tienda;
  categorias: Categoria[];
  menu?: MenuItem[];
  mostrarBuscador?: boolean;
}

import SearchBar from '~/components/SearchBar.astro';
import CartBadge from '~/components/CartBadge.astro';
const { tienda, categorias, menu = [], mostrarBuscador } = Astro.props;
---
<style is:global>
  /* M5.B: dropdown CSS-only (sin JS) en Fashion Bold. is:global -> no agrega data-astro-cid (canario
     fallback byte-identico). Clases fb-nav-* unicas. */
  .fb-nav-dropdown { display: none; }
  .fb-nav-group:hover > .fb-nav-dropdown,
  .fb-nav-group:focus-within > .fb-nav-dropdown { display: block; }
  /* MOBILE.B: drawer del menu (checkbox-hack, sin JS). Desktop (md+) SIEMPRE oculto. */
  .fb-menu-panel { display: none; }
  .fb-menu-cb:checked ~ .fb-menu-panel { display: block; }
  .fb-menu-acc[open] > summary .fb-menu-chev { transform: rotate(180deg); }
  @media (min-width: 768px) { .fb-menu-panel { display: none !important; } }
  /* M5.C: tamano de texto del menu (escala desde el theme). var ausente => *1 = 12px (identico). Mayor
     especificidad que .text-[12px] -> override sin tocar el HTML. El carrito (text-[12px] PERO fuera del
     <nav aria-label="Categorias">) NO entra al selector -> no se escala (decision: solo el menu). */
  .fb-nav-menu a,
  .fb-menu-panel a,
  .fb-menu-panel summary { font-size: calc(12px * var(--nav-text-scale, 1)); }
</style>

<header
  class="sticky top-0 z-40 h-[60px] md:h-[72px] border-b border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)]/90 backdrop-blur-md"
>
  {menu.length > 0 && <input type="checkbox" id="fb-menu-cb" class="fb-menu-cb" hidden />}
  <div class="mx-auto flex h-full max-w-screen-2xl items-center justify-between px-6 md:px-12">
    {/* MOBILE.B: hamburguesa (solo mobile, md:hidden). Abre el drawer de abajo. */}
    {menu.length > 0 && (
      <label for="fb-menu-cb" class="fb-menu-btn md:hidden -ml-1 flex cursor-pointer items-center p-2 text-[var(--ta-color-text-base)]" aria-label="Abrir menu" role="button" tabindex="0">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </label>
    )}
    {/* Logo wordmark — display font, uppercase, tight tracking */}
    <a
      href="/"
      class="font-display text-xl md:text-2xl uppercase tracking-[-0.02em] text-[var(--ta-color-text-base)]"
      aria-label={tienda.nombre_negocio}
    >
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt={tienda.nombre_negocio}
          width="36"
          height="36"
          class="h-9 w-9 object-contain"
          loading="eager"
        />
      ) : (
        <span class="font-bold">{tienda.nombre_negocio}</span>
      )}
    </a>

    {/* Nav uppercase tracking-wide. Underline grueso animado en hover. M5.B: items del arbol; con
        hijos -> dropdown CSS-only. Sin hijos -> <a> identico al de hoy (fallback). */}
    {menu.length > 0 && (
      <nav class="fb-nav-menu hidden md:flex items-center gap-8" aria-label="Categorias">
        {menu.slice(0, 5).map((item) => (item.children.length > 0 ? (
          <div class="fb-nav-group relative">
            <a
              href={item.href}
              class="group relative text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)] transition-opacity hover:opacity-80"
              aria-haspopup="true"
            >
              {item.label}
              <span class="absolute -bottom-1 left-0 right-0 h-[3px] origin-left scale-x-0 bg-[var(--ta-color-accent)] transition-transform duration-200 ease-out group-hover:scale-x-100"></span>
            </a>
            <div class="fb-nav-dropdown absolute left-0 top-full z-50 pt-3">
              <ul class="min-w-[12rem] border border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)] py-1 shadow-lg">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)] transition-opacity hover:opacity-70"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="group relative text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)] transition-opacity hover:opacity-80"
          >
            {item.label}
            <span class="absolute -bottom-1 left-0 right-0 h-[3px] origin-left scale-x-0 bg-[var(--ta-color-accent)] transition-transform duration-200 ease-out group-hover:scale-x-100"></span>
          </a>
        )))}
      </nav>
    )}

    {/* Iconos derecha: Search + Cart */}
    <div class="flex items-center gap-4">
      {mostrarBuscador && <SearchBar template="fashion_bold" />}
      <a
        href="/carrito"
        class="relative flex items-center gap-2 text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)] hover:opacity-80"
        aria-label="Carrito"
        data-cart-icon
      >
        <CartBadge />
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="hidden lg:inline">Bolsa</span>
      </a>
    </div>
  </div>

  {/* MOBILE.B: drawer (full-width baja del header). Todo el arbol (sin limite). Hijos -> <details>. */}
  {menu.length > 0 && (
    <div class="fb-menu-panel md:hidden max-h-[80vh] overflow-y-auto border-t border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)]">
      <nav class="mx-auto max-w-screen-2xl px-6 py-1" aria-label="Menu movil">
        <ul class="divide-y divide-[var(--ta-color-text-base)]/5">
          {menu.map((item) => (
            <li>
              {item.children.length > 0 ? (
                <details class="fb-menu-acc">
                  <summary class="flex cursor-pointer list-none items-center justify-between py-3 text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)]">
                    <span>{item.label}</span>
                    <svg class="fb-menu-chev transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
                  </summary>
                  <ul class="pb-2">
                    <li><a href={item.href} class="block py-2 pl-3 text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)]/70">Ver {item.label}</a></li>
                    {item.children.map((child) => (
                      <li><a href={child.href} class="block py-2 pl-3 text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)]/70">{child.label}</a></li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a href={item.href} class="block py-3 text-[12px] font-semibold uppercase tracking-[0.08em] text-[var(--ta-color-text-base)]">{item.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</header>
