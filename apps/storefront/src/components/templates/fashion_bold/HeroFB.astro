---
// Fashion Bold · Hero · v2 · 2026-06-01 agency-level rewrite
// Type-first full-bleed. Mega-type Anton drench fondo primary. NO eyebrow tracked.
// NO logo placeholder. UN solo CTA. Motion: reveal vertical mask + scroll parallax.

interface Tienda {
  nombre_negocio: string;
  ciudad_negocio?: string | null;
}

interface Props {
  tienda: Tienda;
}

const { tienda } = Astro.props;
const ciudad = (tienda.ciudad_negocio || '').toUpperCase();
---

<section
  class="fb-hero relative h-[88vh] min-h-[640px] w-full overflow-hidden bg-[var(--ta-color-primary)] text-[var(--ta-color-on-primary)]"
  aria-label={`Bienvenida a ${tienda.nombre_negocio}`}
>
  {/* Halftone radial sutil — textura no template. CSS pure, no glass. */}
  <div
    class="fb-grain absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background-image:radial-gradient(ellipse 80% 50% at 100% 0%, color-mix(in oklab, var(--ta-color-accent) 18%, transparent), transparent 60%), radial-gradient(ellipse 60% 40% at 0% 100%, color-mix(in oklab, var(--ta-color-text-base) 25%, transparent), transparent 55%);"
  ></div>

  {/* Diagonal accent bar bottom — corner stamp, no decorative bloat */}
  <span
    class="fb-stamp absolute bottom-0 right-0 hidden md:block"
    aria-hidden="true"
    style="width:clamp(200px,28vw,420px);height:6px;background:var(--ta-color-accent);"
  ></span>

  <div class="relative h-full grid content-end pb-14 md:pb-20 px-6 md:px-12 lg:px-20">
    <p class="fb-meta font-body text-[11px] md:text-xs font-medium opacity-80 mb-4" style="font-feature-settings:'tnum' on;">
      {ciudad ? `${ciudad} · ` : ''}DESDE 2026 · ENVIO NACIONAL
    </p>

    <h1
      class="fb-h1 font-display leading-[0.86] tracking-[-0.04em] text-balance"
      style="font-size:clamp(3rem, 11vw, 9.5rem); text-transform:uppercase;"
    >
      <span class="fb-line">{tienda.nombre_negocio}</span>
    </h1>

    <div class="mt-10 md:mt-14 flex items-center gap-6 md:gap-10">
      <a
        href="#productos"
        class="fb-cta group inline-flex items-center gap-3 bg-[var(--ta-color-accent)] px-9 md:px-12 py-5 md:py-6 font-body text-sm md:text-base font-bold tracking-tight text-[var(--ta-color-on-accent)] transition-transform duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform hover:-translate-y-0.5"
        style="border-radius:0;"
      >
        Comprar coleccion
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">
          <path d="M5 12h14" />
          <path d="M13 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>

  <style>
    .fb-h1 .fb-line {
      display: inline-block;
      transform: translateY(28px);
      opacity: 0;
      animation: fbReveal 720ms cubic-bezier(0.22, 1, 0.36, 1) 80ms forwards;
    }
    .fb-meta, .fb-cta {
      opacity: 0;
      animation: fbFade 600ms cubic-bezier(0.22, 1, 0.36, 1) 480ms forwards;
    }
    .fb-cta { animation-delay: 640ms; }
    @keyframes fbReveal {
      to { transform: translateY(0); opacity: 1; }
    }
    @keyframes fbFade {
      to { opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .fb-h1 .fb-line, .fb-meta, .fb-cta { animation: none; opacity: 1; transform: none; }
    }
  </style>
</section>
