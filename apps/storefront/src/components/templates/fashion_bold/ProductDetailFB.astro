---
// Fashion Bold · ProductDetail (PDP) · Fase F (F1).
// Streetwear editorial: grid 2-col, display font uppercase, tracking agresivo,
// border-radius 0, alto contraste, separadores borde grueso.
import ProductGallery from '~/components/ProductGallery.astro';
import VariantSelector from '~/components/VariantSelector.astro';
import ProductGrid from '~/components/ProductGrid.astro';
import { normalizeEditorial } from '~/lib/pdp-editorial';
interface Props { pdp: any }
const { pdp } = Astro.props;
const p = pdp.producto;
// F3: contenido editorial por-producto (guia de tallas + ficha). Bloques solo si hay datos.
const ed = normalizeEditorial(p);
---

<article class="fb-pdp">
  <div class="fb-pdp__top">
    <section class="fb-pdp__gallery" aria-label="Imagenes del producto">
      <ProductGallery pdp={pdp} template="fashion_bold" />
    </section>
    <section class="fb-pdp__info">
      <nav class="fb-pdp__crumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a><span aria-hidden="true"> / </span><span>{p.nombre}</span>
      </nav>
      <h1 class="fb-pdp__title">{p.nombre}</h1>
      {p.referencia && <p class="fb-pdp__sku">Ref: {p.referencia}</p>}
      <VariantSelector pdp={pdp} template="fashion_bold" />{ed.guiaUrl && (
        <details class="fb-pdp__guia">
          <summary class="fb-pdp__guia-sum"><span>Guía de tallas</span><span class="fb-pdp__guia-icon" aria-hidden="true"></span></summary>
          <div class="fb-pdp__guia-body"><img src={ed.guiaUrl} alt="Guía de tallas" class="fb-pdp__guia-img" loading="lazy" /></div>
        </details>
      )}
    </section>
  </div>

  {(p.descripcion || ed.hasFicha) && (
    <section class="fb-pdp__desc">
      <h2 class="fb-pdp__h2">Descripcion</h2>
      {p.descripcion && <p class="fb-pdp__desc-body">{p.descripcion}</p>}{ed.hasFicha && (
        <div class="fb-pdp__ficha">
          {ed.material && (
            <div class="fb-pdp__ficha-row">
              <h3 class="fb-pdp__ficha-label">Material</h3>
              <p class="fb-pdp__ficha-text">{ed.material}</p>
            </div>
          )}
          {ed.ajuste && (
            <div class="fb-pdp__ficha-row">
              <h3 class="fb-pdp__ficha-label">Ajuste</h3>
              <p class="fb-pdp__ficha-text">{ed.ajuste}</p>
            </div>
          )}
          {ed.diseno.length > 0 && (
            <div class="fb-pdp__ficha-row">
              <h3 class="fb-pdp__ficha-label">Diseño</h3>
              <ul class="fb-pdp__ficha-list">{ed.diseno.map((d) => <li>{d}</li>)}</ul>
            </div>
          )}
          {ed.beneficios.length > 0 && (
            <div class="fb-pdp__ficha-row">
              <h3 class="fb-pdp__ficha-label">Beneficios</h3>
              <ul class="fb-pdp__ficha-list">{ed.beneficios.map((d) => <li>{d}</li>)}</ul>
            </div>
          )}
        </div>
      )}
    </section>
  )}

  {pdp.relacionados.length > 0 && (
    <section class="fb-pdp__rel">
      <h2 class="fb-pdp__h2">Tambien te puede interesar</h2>
      <ProductGrid productos={pdp.relacionados} />
    </section>
  )}
</article>

<style>
  .fb-pdp__top { display: grid; gap: 0; }
  @media (min-width: 1024px) { .fb-pdp__top { grid-template-columns: 1fr 1fr; gap: 0; align-items: start; } }
  .fb-pdp__gallery { border-right: none; }
  @media (min-width: 1024px) { .fb-pdp__gallery { border-right: 2px solid var(--ta-color-text-base); } }

  /* Breadcrumb: uppercase tiny tracking-wide */
  .fb-pdp__crumb {
    font-family: var(--ta-font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: color-mix(in oklab, var(--ta-color-text-base) 55%, transparent);
    margin-bottom: 1rem;
    padding: 1.5rem 1.5rem 0;
  }
  @media (min-width: 1024px) { .fb-pdp__crumb { padding: 2rem 2.5rem 0; } }
  .fb-pdp__crumb a:hover { text-decoration: underline; }

  /* Info panel con padding interno */
  .fb-pdp__info { padding: 0 1.5rem 2rem; }
  @media (min-width: 1024px) { .fb-pdp__info { padding: 0 2.5rem 3rem; } }

  /* Título: display font UPPERCASE, tracking negativo, muy grande */
  .fb-pdp__title {
    font-family: var(--ta-font-display);
    font-size: clamp(2rem, 5vw + 0.5rem, 3.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.92;
    color: var(--ta-color-text-base);
    margin-bottom: 0.6rem;
    word-break: break-word;
  }

  /* SKU: misma familia, muy pequeño */
  .fb-pdp__sku {
    margin-top: 0.35rem;
    margin-bottom: 1.25rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: color-mix(in oklab, var(--ta-color-text-base) 45%, transparent);
    font-family: var(--ta-font-body);
  }

  /* Descripción */
  .fb-pdp__desc {
    margin-top: 3rem;
    max-width: 65ch;
    padding-top: 2rem;
    border-top: 2px solid var(--ta-color-text-base);
  }
  .fb-pdp__h2 {
    font-family: var(--ta-font-display);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ta-color-text-base);
    margin-bottom: 0.75rem;
  }
  .fb-pdp__desc-body {
    white-space: pre-line;
    color: color-mix(in oklab, var(--ta-color-text-base) 80%, transparent);
    font-family: var(--ta-font-body);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* Relacionados */
  .fb-pdp__rel {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid var(--ta-color-text-base);
  }
  .fb-pdp__rel .fb-pdp__h2 { margin-bottom: 1.5rem; }

  /* F3: guia de tallas (colapsable nativo, no-JS) */
  .fb-pdp__guia { margin-top: 2rem; border: 2px solid var(--ta-color-text-base); }
  .fb-pdp__guia-sum { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; padding: 0.85rem 1rem; cursor: pointer; font-family: var(--ta-font-display); font-size: 0.72rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ta-color-text-base); list-style: none; }
  .fb-pdp__guia-sum::-webkit-details-marker { display: none; }
  .fb-pdp__guia-icon { width: 0.6rem; height: 0.6rem; border-right: 2px solid currentColor; border-bottom: 2px solid currentColor; transform: rotate(45deg); transition: transform 0.2s ease; flex: none; }
  .fb-pdp__guia[open] .fb-pdp__guia-icon { transform: rotate(-135deg); }
  .fb-pdp__guia-body { padding: 0 1rem 1rem; }
  .fb-pdp__guia-img { width: 100%; height: auto; display: block; }

  /* F3: ficha editorial (sub-bloques bajo la descripcion) */
  .fb-pdp__ficha { margin-top: 2rem; display: grid; gap: 1.25rem; }
  .fb-pdp__ficha-label { font-family: var(--ta-font-display); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ta-color-text-base); margin-bottom: 0.35rem; }
  .fb-pdp__ficha-text { color: color-mix(in oklab, var(--ta-color-text-base) 80%, transparent); font-family: var(--ta-font-body); font-size: 0.9rem; line-height: 1.65; white-space: pre-line; }
  .fb-pdp__ficha-list { list-style: none; display: grid; gap: 0.4rem; }
  .fb-pdp__ficha-list li { position: relative; padding-left: 1.1rem; color: color-mix(in oklab, var(--ta-color-text-base) 80%, transparent); font-family: var(--ta-font-body); font-size: 0.9rem; line-height: 1.5; }
  .fb-pdp__ficha-list li::before { content: "—"; position: absolute; left: 0; color: var(--ta-color-text-base); }
</style>
