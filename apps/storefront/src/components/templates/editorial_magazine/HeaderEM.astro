---
// Editorial Magazine · Header · 2026-06-01
// Floating top-6, logo Fraunces small-caps izquierda, nav inline derecha 3 links.
// Hairline ink al scroll. Cero centered logo.

interface Tienda {
  nombre_negocio: string;
  logo_url: string | null;
}

interface Categoria {
  id: string;
  nombre: string;
  slug: string;
  orden: number;
}

import type { MenuItem } from '~/lib/menu';

interface Props {
  tienda: Tienda;
  categorias: Categoria[];
  menu?: MenuItem[];
  mostrarBuscador?: boolean;
}

import SearchBar from '~/components/SearchBar.astro';
import CartBadge from '~/components/CartBadge.astro';
const { tienda, categorias, menu = [], mostrarBuscador } = Astro.props;
---

<header class="em-header sticky top-0 z-40 transition-[background-color,border-bottom-color] duration-300">
  {menu.length > 0 && <input type="checkbox" id="em-menu-cb" class="em-menu-cb" hidden />}
  <div class="mx-auto max-w-[1440px] px-6 md:px-10 lg:px-20 h-20 lg:h-24 flex items-center justify-between gap-6">
    {menu.length > 0 && (
      <label for="em-menu-cb" class="em-menu-btn lg:hidden -ml-1 flex cursor-pointer items-center p-2 text-[var(--ta-color-text-base)]" aria-label="Abrir menu" role="button" tabindex="0">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </label>
    )}
    <a href="/" class="flex items-center gap-3 group" aria-label={tienda.nombre_negocio}>
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt={tienda.nombre_negocio}
          width="32"
          height="32"
          loading="eager"
          class="h-8 w-8 object-contain"
        />
      ) : null}
      <span
        class="font-display text-[20px] lg:text-[22px] text-[var(--ta-color-text-base)] transition-colors duration-200 group-hover:text-[var(--ta-color-primary)]"
        style="font-weight:500; font-style:italic; letter-spacing:-0.02em; font-variation-settings:'opsz' 36;"
      >
        {tienda.nombre_negocio}
      </span>
    </a>

    <nav class="em-nav-menu hidden lg:flex items-center gap-9" aria-label="Categorias">
      {menu.slice(0, 4).map((item) => (item.children.length > 0 ? (
        <div class="em-nav-group relative">
          <a
            href={item.href}
            class="font-body text-[13px] font-medium text-[var(--ta-color-text-base)]/72 hover:text-[var(--ta-color-text-base)] transition-colors duration-200"
            aria-haspopup="true"
          >
            {item.label}
          </a>
          <div class="em-nav-dropdown absolute left-0 top-full z-50 pt-3">
            <ul class="min-w-[12rem] rounded-sm border border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)] py-1 shadow-lg">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="block px-4 py-2 font-body text-[13px] font-medium text-[var(--ta-color-text-base)]/72 hover:text-[var(--ta-color-text-base)] transition-colors duration-200"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ) : (
        <a
          href={item.href}
          class="font-body text-[13px] font-medium text-[var(--ta-color-text-base)]/72 hover:text-[var(--ta-color-text-base)] transition-colors duration-200"
        >
          {item.label}
        </a>
      )))}
    </nav>

    <div class="flex items-center gap-5">
      {mostrarBuscador && <SearchBar template="editorial_magazine" />}
      <a
        href="/carrito"
        class="flex items-center gap-2 font-body text-[13px] font-medium text-[var(--ta-color-text-base)]/80 hover:text-[var(--ta-color-text-base)] transition-colors duration-200"
        aria-label="Carrito"
        data-cart-icon
      >
        <CartBadge />
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="hidden md:inline">Carrito</span>
      </a>
    </div>
  </div>
  <span class="em-rule block h-px bg-[var(--ta-color-text-base)]/10"></span>

  {/* MOBILE.B: drawer (full-width baja del header). Todo el arbol (sin limite). Hijos -> <details>. */}
  {menu.length > 0 && (
    <div class="em-menu-panel lg:hidden max-h-[80vh] overflow-y-auto bg-[var(--ta-color-bg-base)]">
      <nav class="mx-auto max-w-[1440px] px-6 md:px-10 py-1" aria-label="Menu movil">
        <ul class="divide-y divide-[var(--ta-color-text-base)]/5">
          {menu.map((item) => (
            <li>
              {item.children.length > 0 ? (
                <details class="em-menu-acc">
                  <summary class="flex cursor-pointer list-none items-center justify-between py-3 font-body text-[13px] font-medium text-[var(--ta-color-text-base)]">
                    <span>{item.label}</span>
                    <svg class="em-menu-chev transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
                  </summary>
                  <ul class="pb-2">
                    <li><a href={item.href} class="block py-2 pl-3 font-body text-[13px] text-[var(--ta-color-text-base)]/72">Ver {item.label}</a></li>
                    {item.children.map((child) => (
                      <li><a href={child.href} class="block py-2 pl-3 font-body text-[13px] text-[var(--ta-color-text-base)]/72">{child.label}</a></li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a href={item.href} class="block py-3 font-body text-[13px] font-medium text-[var(--ta-color-text-base)]">{item.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</header>

<style>
  .em-header {
    background-color: color-mix(in oklab, var(--ta-color-bg-base) 88%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  /* M5.B: dropdown CSS-only (sin JS). EM ya scopea (este <style>), por eso va aca y no is:global. */
  .em-nav-dropdown { display: none; }
  .em-nav-group:hover > .em-nav-dropdown,
  .em-nav-group:focus-within > .em-nav-dropdown { display: block; }
  /* MOBILE.B: drawer del menu (checkbox-hack, sin JS). Va aca (scoped existente, regla dura). Desktop oculto. */
  .em-menu-panel { display: none; }
  .em-menu-cb:checked ~ .em-menu-panel { display: block; }
  .em-menu-acc[open] > summary .em-menu-chev { transform: rotate(180deg); }
  @media (min-width: 1024px) { .em-menu-panel { display: none !important; } }
  /* M5.C: tamano de texto del menu (escala desde el theme). var ausente => *1 = 13px (identico). Va en
     este <style> scoped existente (regla dura M5: nada de scoped nuevo). El carrito esta en un <div>
     (no en un <nav>) -> el selector solo alcanza el menu. */
  .em-nav-menu a,
  .em-menu-panel a,
  .em-menu-panel summary { font-size: calc(13px * var(--nav-text-scale, 1)); }
</style>
