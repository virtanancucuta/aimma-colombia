---
// Editorial Magazine · ProductDetail (PDP) · Fase F (F1).
// Revista Vogue/Kinfolk: Fraunces italic light/300, separadores accent hairline,
// mucho aire vertical, breadcrumb muted tabular, h2 con separador ornamental.
import ProductGallery from '~/components/ProductGallery.astro';
import VariantSelector from '~/components/VariantSelector.astro';
import ProductGrid from '~/components/ProductGrid.astro';
interface Props { pdp: any }
const { pdp } = Astro.props;
const p = pdp.producto;
---

<article class="em-pdp">
  <div class="em-pdp__top">
    <section class="em-pdp__gallery" aria-label="Imagenes del producto">
      <ProductGallery pdp={pdp} template="editorial_magazine" />
    </section>
    <section class="em-pdp__info">
      <nav class="em-pdp__crumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a><span aria-hidden="true"> / </span><span>{p.nombre}</span>
      </nav>
      <h1 class="em-pdp__title">{p.nombre}</h1>
      {p.referencia && <p class="em-pdp__sku">Ref: {p.referencia}</p>}
      <VariantSelector pdp={pdp} template="editorial_magazine" />
    </section>
  </div>

  {p.descripcion && (
    <section class="em-pdp__desc">
      <h2 class="em-pdp__h2"><span class="em-pdp__h2-rule" aria-hidden="true"></span>Descripcion<span class="em-pdp__h2-rule" aria-hidden="true"></span></h2>
      <p class="em-pdp__desc-body">{p.descripcion}</p>
    </section>
  )}

  {pdp.relacionados.length > 0 && (
    <section class="em-pdp__rel">
      <h2 class="em-pdp__h2"><span class="em-pdp__h2-rule" aria-hidden="true"></span>Tambien te puede interesar<span class="em-pdp__h2-rule" aria-hidden="true"></span></h2>
      <ProductGrid productos={pdp.relacionados} />
    </section>
  )}
</article>

<style>
  .em-pdp__top { display: grid; gap: 3rem; }
  @media (min-width: 1024px) { .em-pdp__top { grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; } }

  /* Breadcrumb: tabular body medium */
  .em-pdp__crumb {
    font-family: var(--ta-font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: color-mix(in oklab, var(--ta-color-text-base) 50%, transparent);
    letter-spacing: 0.02em;
    margin-bottom: 1.25rem;
  }
  .em-pdp__crumb a:hover { color: var(--ta-color-text-base); }

  /* Título: Fraunces italic 300 — signature EM */
  .em-pdp__title {
    font-family: var(--ta-font-display);
    font-size: clamp(1.85rem, 3.5vw + 0.5rem, 3rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: -0.012em;
    line-height: 1.12;
    color: var(--ta-color-text-base);
    font-variation-settings: 'opsz' 36;
    margin-bottom: 0.75rem;
  }

  /* SKU: body light tabular */
  .em-pdp__sku {
    margin-top: 0.4rem;
    margin-bottom: 2rem;
    font-family: var(--ta-font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: color-mix(in oklab, var(--ta-color-text-base) 45%, transparent);
  }

  /* Descripción */
  .em-pdp__desc {
    margin-top: 3.5rem;
    max-width: 64ch;
  }

  /* h2 ornamental: línea hairline + texto centrado */
  .em-pdp__h2 {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--ta-font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--ta-color-text-base) 55%, transparent);
    margin-bottom: 1.5rem;
    white-space: nowrap;
  }
  .em-pdp__h2-rule {
    flex: 1;
    display: block;
    height: 1px;
    background: color-mix(in oklab, var(--ta-color-text-base) 18%, transparent);
  }

  .em-pdp__desc-body {
    white-space: pre-line;
    font-family: var(--ta-font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.7;
    letter-spacing: -0.01em;
    color: color-mix(in oklab, var(--ta-color-text-base) 80%, transparent);
    font-variation-settings: 'opsz' 36;
  }

  /* Relacionados */
  .em-pdp__rel { margin-top: 4.5rem; }
  .em-pdp__rel .em-pdp__h2 { margin-bottom: 2rem; }
</style>
