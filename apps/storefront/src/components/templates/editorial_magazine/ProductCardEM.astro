---
// Editorial Magazine · ProductCard · 2026-06-01
// aspect-[4/5] sin radius sin shadow. Hover crossfade 700ms. Title Fraunces italic.
// Precio Inter tabular alineado derecha. NO badges agresivos.

import OptimizedImage from '~/components/OptimizedImage.astro';

interface Props {
  producto: {
    id: string;
    nombre: string;
    slug: string;
    precio: number;
    precio_anterior?: number | null;
    foto_principal?: string | null;
    foto_hover?: string | null;
    stock_disponible?: number | null;
    referencia?: string | null;
  };
  hoverSegundaFoto?: boolean;
}

const { producto, hoverSegundaFoto = false } = Astro.props;

const fmt = (n: number) =>
  new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);

const precioStr = fmt(producto.precio);
const precioAnteriorStr = producto.precio_anterior ? fmt(producto.precio_anterior) : null;
const enDescuento = producto.precio_anterior !== null && producto.precio_anterior !== undefined && producto.precio_anterior > producto.precio;
const sinStock = producto.stock_disponible === 0;
---

<article class="em-card group">
  <a href={`/p/${producto.slug}`} class="block" aria-label={producto.nombre}>
    {/* Image 1:1 cuadrada (estandar multi-rubro, patron B) */}
    <div class="relative aspect-square overflow-hidden bg-[var(--ta-color-text-base)]/[0.04]">
      {producto.foto_principal ? (
        <OptimizedImage
          src={producto.foto_principal}
          alt={producto.nombre}
          width={400}
          height={400}
          loading="lazy"
          class="absolute inset-0 w-full aspect-square object-cover transition-[transform,opacity] duration-[700ms] ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform group-hover:scale-[1.04]"
          transitionName={`producto-${producto.id}`}
        />
      ) : (
        <div class="flex h-full items-center justify-center p-8">
          <span
            class="font-display italic text-center text-[var(--ta-color-text-base)]/40 line-clamp-3 max-w-[16ch]"
            style="font-size:clamp(1rem, 2.4vw, 1.5rem); line-height:1.15; font-weight:300; letter-spacing:-0.015em; font-variation-settings:'opsz' 36;"
          >
            {producto.nombre}
          </span>
        </div>
      )}

      {/* Fase A: segunda foto al hover (CSS-only, decorativa, lazy). object-cover, fade 700ms. */}
      {hoverSegundaFoto && producto.foto_hover && (
        <OptimizedImage
          src={producto.foto_hover}
          alt=""
          width={400}
          height={400}
          loading="lazy"
          class="absolute inset-0 w-full aspect-square object-cover opacity-0 transition-opacity duration-[700ms] ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:opacity-100 group-focus-within:opacity-100 motion-reduce:transition-none"
        />
      )}

      {sinStock && (
        <div class="absolute inset-0 flex items-end bg-[var(--ta-color-bg-base)]/45 p-5">
          <span class="font-body text-[11px] text-[var(--ta-color-text-base)]" style="letter-spacing:0.02em;">
            Agotado por ahora
          </span>
        </div>
      )}

      {enDescuento && !sinStock && (
        <span class="absolute left-4 top-4 font-body text-[11px] text-[var(--ta-color-text-base)]/70" style="letter-spacing:0.02em;">
          En oferta
        </span>
      )}
    </div>

    <div class="mt-5 flex items-start justify-between gap-6">
      <h3
        class="font-display italic text-[var(--ta-color-text-base)] line-clamp-2"
        style="font-size:17px; font-weight:400; line-height:1.25; letter-spacing:-0.012em; font-variation-settings:'opsz' 36;"
      >
        {producto.nombre}
      </h3>
      <div class="shrink-0 text-right">
        <span class="font-body text-[14px] font-medium tabular-nums text-[var(--ta-color-text-base)]">
          {precioStr}
        </span>
        {precioAnteriorStr && enDescuento && (
          <span class="block font-body text-[11px] tabular-nums text-[var(--ta-color-text-base)]/50 line-through mt-0.5">
            {precioAnteriorStr}
          </span>
        )}
      </div>
    </div>
  </a>
</article>
