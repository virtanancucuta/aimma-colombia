---
// Editorial Magazine · Hero · 2026-06-01
// Asimetrico 60/40. Statement tipografico + pull quote + dropcap.
// Fraunces opsz max. NO eyebrow tracked. NO logo placeholder. UN CTA link.

interface Tienda {
  nombre_negocio: string;
  ciudad_negocio?: string | null;
}

interface Props {
  tienda: Tienda;
}

const { tienda } = Astro.props;
const firstLetter = tienda.nombre_negocio.charAt(0);
const rest = tienda.nombre_negocio.slice(1);
---

<section class="em-hero relative pt-20 pb-24 lg:pt-32 lg:pb-40">
  <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-end">
    {/* Statement col 7 — anclado abajo izquierda */}
    <div class="lg:col-span-7 em-fade">
      <p class="font-body text-[13px] text-[var(--ta-color-text-base)]/55 mb-8" style="font-variation-settings:'tnum' on;">
        Volumen <span class="tabular-nums">{new Date().getFullYear() - 2025}</span> · Coleccion en curso
      </p>

      <h1
        class="font-display text-[var(--ta-color-text-base)] text-balance"
        style="font-size:clamp(2.75rem, 7vw, 6rem); font-weight:300; line-height:0.98; letter-spacing:-0.04em; font-variation-settings:'opsz' 144;"
      >
        <span class="em-dropcap" aria-hidden="true">{firstLetter}</span><span class="sr-only">{firstLetter}</span>{rest}
      </h1>

      <p
        class="mt-10 max-w-[44ch] font-display text-[var(--ta-color-text-base)]/70"
        style="font-size:clamp(1.05rem, 1.6vw, 1.35rem); font-style:italic; font-weight:400; line-height:1.5; font-variation-settings:'opsz' 36;"
      >
        Una seleccion editorial de piezas pensadas pieza por pieza.
        Pedido por WhatsApp, hecho con calma.
      </p>

      <a
        href="#productos"
        class="em-link mt-12 lg:mt-16 inline-flex items-baseline gap-3 font-body text-[14px] font-medium text-[var(--ta-color-text-base)] w-fit"
      >
        <span class="em-underline">Leer la coleccion</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>

    {/* Pull quote col 5 derecha — replaza logo placeholder */}
    <aside class="lg:col-span-5 em-fade" style="animation-delay:200ms;">
      <figure class="relative">
        <span aria-hidden="true" class="em-marker font-display text-[var(--ta-color-primary)] block leading-none" style="font-size:clamp(5rem, 10vw, 8rem); font-weight:300; font-style:italic; font-variation-settings:'opsz' 144;">&ldquo;</span>
        <blockquote class="-mt-8 lg:-mt-12 pl-4 lg:pl-8 border-l border-[var(--ta-color-text-base)]/15">
          <p
            class="font-display italic text-[var(--ta-color-text-base)]"
            style="font-size:clamp(1.3rem, 2.3vw, 1.85rem); font-weight:400; line-height:1.34; letter-spacing:-0.012em; font-variation-settings:'opsz' 96;"
          >
            La pieza correcta encuentra a quien la espera. Aqui curamos el encuentro.
          </p>
          <figcaption class="mt-6 font-body text-[12px] text-[var(--ta-color-text-base)]/55">
            Editor en jefe
          </figcaption>
        </blockquote>
      </figure>
    </aside>
  </div>

  <style>
    .em-dropcap {
      display: inline-block;
      color: var(--ta-color-primary);
      font-style: italic;
      font-weight: 300;
      font-variation-settings: 'opsz' 144;
      transform: translateY(0.06em);
    }
    .em-fade {
      opacity: 0;
      transform: translateY(10px);
      animation: emFade 900ms cubic-bezier(0.22, 1, 0.36, 1) 100ms forwards;
    }
    .em-link { transition: gap 220ms cubic-bezier(0.4, 0, 0.2, 1); }
    .em-link:hover { gap: 1.25rem; }
    .em-underline {
      position: relative;
      padding-bottom: 2px;
      background-image: linear-gradient(currentColor, currentColor);
      background-position: 0 100%;
      background-size: 100% 1px;
      background-repeat: no-repeat;
    }
    @keyframes emFade {
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .em-fade { animation: none; opacity: 1; transform: none; }
    }
  </style>
</section>
