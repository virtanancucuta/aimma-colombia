---
// Editorial Magazine · Hero · v2 · 2026-06-01
// Cormorant Garamond (no Fraunces). Accent dorado en eyebrow + dropcap +
// marker quote + hairlines. UN sola fuente serif para diferenciar de MA.

interface Tienda {
  nombre_negocio: string;
  ciudad_negocio?: string | null;
}

interface Props {
  tienda: Tienda;
}

const { tienda } = Astro.props;
const firstLetter = tienda.nombre_negocio.charAt(0);
const rest = tienda.nombre_negocio.slice(1);
---

<section class="em-hero relative pt-20 pb-24 lg:pt-32 lg:pb-40">
  {/* Eyebrow editorial — accent dorado + rule */}
  <div class="em-fade flex items-baseline gap-4 mb-12 lg:mb-16">
    <span class="block h-px flex-1 max-w-[120px] bg-[var(--ta-color-accent)]"></span>
    <p class="font-body text-[12px] tracking-[0.18em] uppercase text-[var(--ta-color-accent)] font-medium">
      Volumen <span class="tabular-nums">{new Date().getFullYear() - 2025}</span> &middot; Coleccion en curso
    </p>
    <span class="block h-px flex-1 bg-[var(--ta-color-accent)]/40"></span>
  </div>

  <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-end">
    {/* Statement col 7 — anclado abajo izquierda */}
    <div class="lg:col-span-7 em-fade" style="animation-delay:120ms;">
      <h1
        class="font-display text-[var(--ta-color-text-base)] text-balance"
        style="font-size:clamp(2.75rem, 7.5vw, 7rem); font-weight:300; line-height:0.95; letter-spacing:-0.015em;"
      >
        <span class="em-dropcap" aria-hidden="true">{firstLetter}</span><span class="sr-only">{firstLetter}</span>{rest}
      </h1>

      <p
        class="mt-10 max-w-[44ch] font-display text-[var(--ta-color-text-base)]/72"
        style="font-size:clamp(1.1rem, 1.7vw, 1.45rem); font-style:italic; font-weight:400; line-height:1.5;"
      >
        Una seleccion editorial de piezas elegidas una por una.
        Pedido por WhatsApp, hecho con calma.
      </p>

      <a
        href="#productos"
        class="em-link mt-12 lg:mt-16 inline-flex items-baseline gap-3 font-body text-[14px] font-medium text-[var(--ta-color-text-base)] w-fit group"
      >
        <span class="em-underline">Leer la coleccion</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>

    {/* Pull quote col 5 derecha — accent dorado en quotation mark + caption */}
    <aside class="lg:col-span-5 em-fade" style="animation-delay:280ms;">
      <figure class="relative">
        <span aria-hidden="true" class="em-marker block leading-none" style="font-family:'Cormorant Garamond',serif; font-size:clamp(5rem, 10vw, 8rem); font-weight:300; font-style:italic; color:var(--ta-color-accent);">&ldquo;</span>
        <blockquote class="-mt-8 lg:-mt-12 pl-4 lg:pl-8 border-l border-[var(--ta-color-accent)]/35">
          <p
            class="font-display italic text-[var(--ta-color-text-base)]"
            style="font-size:clamp(1.3rem, 2.3vw, 1.85rem); font-weight:400; line-height:1.32; letter-spacing:-0.005em;"
          >
            La pieza correcta encuentra a quien la espera. Aqui curamos el encuentro.
          </p>
          <figcaption class="mt-6 flex items-baseline gap-3 font-body text-[12px] text-[var(--ta-color-text-base)]/55">
            <span class="block h-px w-8 bg-[var(--ta-color-accent)]"></span>
            Editor en jefe
          </figcaption>
        </blockquote>
      </figure>
    </aside>
  </div>

  <style>
    .em-dropcap {
      display: inline-block;
      color: var(--ta-color-accent);
      font-style: italic;
      font-weight: 300;
    }
    .em-fade {
      opacity: 0;
      transform: translateY(10px);
      animation: emFade 900ms cubic-bezier(0.22, 1, 0.36, 1) 100ms forwards;
    }
    .em-link { transition: gap 220ms cubic-bezier(0.4, 0, 0.2, 1); }
    .em-link:hover { gap: 1.25rem; }
    .em-underline {
      position: relative;
      padding-bottom: 2px;
      background-image: linear-gradient(currentColor, currentColor);
      background-position: 0 100%;
      background-size: 100% 1px;
      background-repeat: no-repeat;
    }
    .em-link:hover .em-underline {
      background-image: linear-gradient(var(--ta-color-accent), var(--ta-color-accent));
      color: var(--ta-color-accent);
    }
    @keyframes emFade {
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .em-fade { animation: none; opacity: 1; transform: none; }
    }
  </style>
</section>
