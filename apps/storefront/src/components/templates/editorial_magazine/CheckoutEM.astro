---
import CheckoutApp from '~/components/CheckoutApp.astro';
interface Props { hasWhatsApp: boolean; efUrl: string; anonKey: string; tiendaSlug: string; tiendaNombre: string }
const { hasWhatsApp, efUrl, anonKey, tiendaSlug, tiendaNombre } = Astro.props;
---
<section class="em-ck mx-auto w-full max-w-2xl px-6 py-10 lg:py-16">
  {hasWhatsApp && (
    <header class="mb-8">
      <p class="font-body text-[13px] text-[var(--ta-color-text-base)]/55 mb-2"><a href="/carrito" class="hover:underline">&larr; Volver al carrito</a></p>
      <h1 class="em-ck__title">Finalizar pedido</h1>
      <p class="mt-3 font-body text-[15px] text-[var(--ta-color-text-base)]/70 leading-[1.55]">Completa tus datos. Al confirmar te abrimos WhatsApp con el resumen del pedido para que coordines con la tienda.</p>
    </header>
  )}
  <CheckoutApp hasWhatsApp={hasWhatsApp} efUrl={efUrl} anonKey={anonKey} tiendaSlug={tiendaSlug} tiendaNombre={tiendaNombre} />
</section>
<style>
  .em-ck__title { font-family: var(--ta-font-display); font-size: clamp(1.85rem,3.5vw + 0.5rem,3rem); font-weight: 300; font-style: italic; letter-spacing: -0.012em; line-height: 1.12; color: var(--ta-color-text-base); font-variation-settings: 'opsz' 36; }
</style>
