---
import CartApp from '~/components/CartApp.astro';
interface Props { hasWhatsApp: boolean; upsell: any[] }
const { hasWhatsApp, upsell } = Astro.props;
---
<section class="ma-cart">
  <header class="ma-cart__head"><h1 class="ma-cart__title">Tu carrito</h1></header>
  <CartApp prefix="ma" hasWhatsApp={hasWhatsApp} upsell={upsell} />
</section>
<style>
  .ma-cart__title { font-family: var(--ta-font-display); font-size: clamp(1.75rem,3.5vw + 0.5rem,2.75rem); font-weight: 300; font-style: italic; letter-spacing: -0.015em; line-height: 1.1; color: var(--ta-color-text-base); font-variation-settings: 'opsz' 48; margin-bottom: 1.5rem; }
</style>
