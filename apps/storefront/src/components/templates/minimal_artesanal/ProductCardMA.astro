---
// Minimal Artesanal · ProductCard · 2026-05-31
// Vertical editorial. aspect-[4/5]. Serif nombre 17px font-normal.
// Precio mono tabular 12px tracking-wide muted. NO badges agresivos.
// Hover: opacity transition 700ms (placeholder para crossfade).

import OptimizedImage from '~/components/OptimizedImage.astro';

interface Props {
  producto: {
    id: string;
    nombre: string;
    slug: string;
    precio: number;
    precio_anterior?: number | null;
    foto_principal?: string | null;
    stock_disponible?: number | null;
    referencia?: string | null;
  };
}

const { producto } = Astro.props;

const fmt = (n: number) =>
  new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);

const precioStr = fmt(producto.precio);
const sinStock = producto.stock_disponible === 0;
---

<article class="group">
  <a href={`/p/${producto.slug}`} class="block" aria-label={producto.nombre}>
    {/* Image aspect-[4/5] editorial */}
    <div class="relative aspect-[4/5] overflow-hidden bg-[var(--ta-color-text-base)]/5">
      {producto.foto_principal ? (
        <OptimizedImage
          src={producto.foto_principal}
          alt={producto.nombre}
          width={400}
          height={500}
          loading="lazy"
          class="h-full w-full object-cover transition-opacity duration-700 ease-out group-hover:opacity-95"
          transitionName={`producto-${producto.id}`}
        />
      ) : (
        <div class="flex h-full items-center justify-center p-8">
          <span
            class="font-display italic text-center text-[var(--ta-color-text-base)]/45 line-clamp-3 max-w-[16ch]"
            style="font-size:clamp(1rem, 2.4vw, 1.5rem); line-height:1.15; font-weight:300; letter-spacing:-0.015em; font-variation-settings:'opsz' 36;"
          >
            {producto.nombre}
          </span>
        </div>
      )}

      {/* Solo "Agotado" text-only sin badge agresivo */}
      {sinStock && (
        <div class="absolute inset-0 flex items-center justify-center bg-[var(--ta-color-bg-base)]/60">
          <span class="font-body text-[11px] uppercase tracking-[0.25em] text-[var(--ta-color-text-base)]">
            Agotado
          </span>
        </div>
      )}
    </div>

    {/* Info debajo */}
    <div class="mt-5 flex items-baseline justify-between gap-4">
      <h3 class="font-display text-[17px] font-normal tracking-tight text-[var(--ta-color-text-base)]">
        {producto.nombre}
      </h3>
      <span class="shrink-0 font-body text-[12px] tabular-nums tracking-wide text-[var(--ta-color-text-base)]/60">
        {precioStr}
      </span>
    </div>
  </a>
</article>
