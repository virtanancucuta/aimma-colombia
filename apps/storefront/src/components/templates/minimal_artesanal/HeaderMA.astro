---
// Minimal Artesanal · Header · 2026-05-31
// Floating editorial. Logo CENTRADO en serif italic, nav split L/R con 3 links
// max c/u. Bar tall 80px. Transparente sobre hero, solid bg al scroll past 100px.
// Tiny labels uppercase tracking-[0.18em] 11px. NO sticky agresivo, NO badges.

interface Tienda {
  nombre_negocio: string;
  logo_url: string | null;
}
interface Categoria {
  id: string;
  nombre: string;
  slug: string;
  orden: number;
}

import type { MenuItem } from '~/lib/menu';

interface Props {
  tienda: Tienda;
  categorias: Categoria[];
  menu?: MenuItem[];
  mostrarBuscador?: boolean;
}

import SearchBar from '~/components/SearchBar.astro';
import CartBadge from '~/components/CartBadge.astro';
const { tienda, categorias, menu = [], mostrarBuscador } = Astro.props;
---
<style is:global>
  /* M5.B: dropdown CSS-only (sin JS) en Minimal Artesanal. is:global -> no agrega data-astro-cid
     (canario fallback byte-identico). Clases ma-nav-* unicas. */
  .ma-nav-dropdown { display: none; }
  .ma-nav-group:hover > .ma-nav-dropdown,
  .ma-nav-group:focus-within > .ma-nav-dropdown { display: block; }
  /* MOBILE.B: drawer del menu (checkbox-hack, sin JS). Desktop (lg+) SIEMPRE oculto. */
  .ma-menu-panel { display: none; }
  .ma-menu-cb:checked ~ .ma-menu-panel { display: block; }
  .ma-menu-acc[open] > summary .ma-menu-chev { transform: rotate(180deg); }
  @media (min-width: 1024px) { .ma-menu-panel { display: none !important; } }
  /* M5.C: tamano de texto del menu (escala desde el theme). var ausente => *1 = 11px (identico). El
     <nav aria-label="Principal"> de MA mezcla menu (ul izq) Y carrito/Contacto (ul der) -> NO uso el nav
     como selector; uso el marker .ma-nav-menu de la ul izquierda. Asi el carrito/Contacto no se escalan. */
  .ma-nav-menu a,
  .ma-menu-panel a,
  .ma-menu-panel summary { font-size: calc(11px * var(--nav-text-scale, 1)); }
</style>

<header
  id="ma-header"
  class="fixed inset-x-0 top-0 z-40 transition-colors duration-500 bg-[var(--ta-color-bg-base)]/0"
>
  {menu.length > 0 && <input type="checkbox" id="ma-menu-cb" class="ma-menu-cb" hidden />}
  <nav class="mx-auto flex h-20 max-w-screen-2xl items-center justify-between gap-8 px-8 lg:px-16" aria-label="Principal">
    {/* Nav izquierda — primeros 3 del arbol. M5.B: con hijos -> dropdown; sin hijos -> <li> identico.
        ma-nav-menu (M5.C): marker para escalar SOLO el texto del menu, no el carrito/Contacto (ul der). */}
    <ul class="ma-nav-menu hidden lg:flex items-center gap-10">
      {menu.slice(0, 3).map((item) => (item.children.length > 0 ? (
        <li class="ma-nav-group relative">
          <a
            href={item.href}
            class="text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65 transition-colors hover:text-[var(--ta-color-text-base)]"
            aria-haspopup="true"
          >
            {item.label}
          </a>
          <div class="ma-nav-dropdown absolute left-0 top-full z-50 pt-3">
            <ul class="min-w-[11rem] border border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)] py-1 shadow-lg">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65 transition-colors hover:text-[var(--ta-color-text-base)]"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ) : (
        <li>
          <a
            href={item.href}
            class="text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65 transition-colors hover:text-[var(--ta-color-text-base)]"
          >
            {item.label}
          </a>
        </li>
      )))}
    </ul>

    {/* Logo CENTRADO serif italic */}
    <a
      href="/"
      class="font-display text-2xl italic tracking-wide text-[var(--ta-color-text-base)]"
      aria-label={tienda.nombre_negocio}
    >
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt={tienda.nombre_negocio}
          width="40"
          height="40"
          {/* !h-10: global.css trae `img { height:auto }` SIN @layer -> pisa el `h-10` de utilities
              (no-layered gana a layered en Tailwind v4). Con w-auto el logo quedaba sin constraint en
              ningun eje = tamano natural gigante. El important fuerza el alto. FB/EM no sufren porque
              fijan el ancho (h-9 w-9 / h-8 w-8). Raiz a corregir aparte: mover esa regla a @layer base. */}
          class="!h-10 w-auto object-contain"
          loading="eager"
        />
      ) : (
        <span>{tienda.nombre_negocio}</span>
      )}
    </a>

    {/* Nav derecha — Buscar + Contacto + Bolsa */}
    <ul class="hidden lg:flex items-center gap-10">
      {mostrarBuscador && <li class="flex items-center"><SearchBar template="minimal_artesanal" /></li>}
      <li>
        <a
          href="/legales/contacto"
          class="text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65 hover:text-[var(--ta-color-text-base)]"
        >
          Contacto
        </a>
      </li>
      <li>
        <a
          href="/carrito"
          class="text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65 hover:text-[var(--ta-color-text-base)]"
          data-cart-icon
        >
          <CartBadge />
          Bolsa
        </a>
      </li>
    </ul>

    {/* Mobile: hamburguesa stroke-1 + logo center (oculta nav links). Bolsa derecha. MOBILE.B: el
        boton decorativo ahora es un <label> que togglea el checkbox (abre el drawer). Sin JS. */}
    <div class="lg:hidden flex items-center justify-between w-full">
      {menu.length > 0 ? (
        <label
          for="ma-menu-cb"
          aria-label="Abrir menu"
          role="button"
          tabindex="0"
          class="ma-menu-btn cursor-pointer text-[var(--ta-color-text-base)]"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
            <line x1="3" y1="8" x2="21" y2="8" />
            <line x1="3" y1="16" x2="21" y2="16" />
          </svg>
        </label>
      ) : (
        <span aria-hidden="true"></span>
      )}
      <a
        href="/carrito"
        class="text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65"
        aria-label="Carrito"
      >
        Bolsa
      </a>
    </div>
  </nav>

  {/* MOBILE.B: drawer (full-width baja del header fijo). Todo el arbol (sin limite). Hijos -> <details>. */}
  {menu.length > 0 && (
    <div class="ma-menu-panel lg:hidden max-h-[80vh] overflow-y-auto border-t border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)]">
      <nav class="mx-auto max-w-screen-2xl px-8 py-1" aria-label="Menu movil">
        <ul class="divide-y divide-[var(--ta-color-text-base)]/5">
          {menu.map((item) => (
            <li>
              {item.children.length > 0 ? (
                <details class="ma-menu-acc">
                  <summary class="flex cursor-pointer list-none items-center justify-between py-3 text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65">
                    <span>{item.label}</span>
                    <svg class="ma-menu-chev transition-transform duration-200" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
                  </summary>
                  <ul class="pb-2">
                    <li><a href={item.href} class="block py-2 pl-3 text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/50">Ver {item.label}</a></li>
                    {item.children.map((child) => (
                      <li><a href={child.href} class="block py-2 pl-3 text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/50">{child.label}</a></li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a href={item.href} class="block py-3 text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-text-base)]/65">{item.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</header>

{/* Spacer para empujar el contenido al inicio (header fixed) */}
<div class="h-20" aria-hidden="true"></div>

<script is:inline>
  // Sticky transparent → solid al scroll past 100px (skill spec)
  (function () {
    const header = document.getElementById('ma-header');
    if (!header) return;
    function update() {
      if (window.scrollY > 100) {
        header.classList.remove('bg-[var(--ta-color-bg-base)]/0');
        header.classList.add('bg-[var(--ta-color-bg-base)]/85', 'backdrop-blur-md', 'border-b', 'border-[var(--ta-color-text-base)]/10');
      } else {
        header.classList.add('bg-[var(--ta-color-bg-base)]/0');
        header.classList.remove('bg-[var(--ta-color-bg-base)]/85', 'backdrop-blur-md', 'border-b', 'border-[var(--ta-color-text-base)]/10');
      }
    }
    update();
    window.addEventListener('scroll', update, { passive: true });
    document.addEventListener('astro:page-load', update);
  })();
</script>
