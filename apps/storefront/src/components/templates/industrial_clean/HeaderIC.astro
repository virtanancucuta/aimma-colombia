---
// Industrial Clean · Header · 2026-05-31
// Swiss Modernism 2.0. Logo izq, nav central, search+cart derecha.
// h-16 sticky + backdrop-blur. Border-bottom para separator industrial.
// Nav medium weight, tracking-wide uppercase 13px, hover color shift al primary.

interface Tienda {
  nombre_negocio: string;
  logo_url: string | null;
}
interface Categoria {
  id: string;
  nombre: string;
  slug: string;
  orden: number;
}

import type { MenuItem } from '~/lib/menu';

interface Props {
  tienda: Tienda;
  categorias: Categoria[];
  menu?: MenuItem[];
  mostrarBuscador?: boolean;
}

import SearchBar from '~/components/SearchBar.astro';
import CartBadge from '~/components/CartBadge.astro';
const { tienda, categorias, menu = [], mostrarBuscador } = Astro.props;
---
<style is:global>
  /* M5: dropdown de subcategorias CSS-only (sin JS). is:global -> Astro NO agrega data-astro-cid a los
     elementos del header (canario: tienda sin nav queda byte-identica). Va al TOP para no dejar espacio
     residual tras </header>. Clases ic-nav-* unicas, sin conflicto. focus-within = accesible por teclado;
     pt-3 del panel = puente de hover (no se pierde el grupo al bajar del trigger al dropdown). */
  .ic-nav-dropdown { display: none; }
  .ic-nav-group:hover > .ic-nav-dropdown,
  .ic-nav-group:focus-within > .ic-nav-dropdown { display: block; }
</style>
<header class="sticky top-0 z-40 border-b border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)]/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-6 px-6 lg:px-8">
    {/* Logo (img or wordmark) */}
    <a
      href="/"
      class="flex items-center gap-3"
      aria-label={tienda.nombre_negocio}
    >
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt={tienda.nombre_negocio}
          width="36"
          height="36"
          class="h-9 w-9 rounded-sm object-contain"
          loading="eager"
        />
      ) : null}
      <span class="font-display text-base font-semibold text-[var(--ta-color-text-base)]">
        {tienda.nombre_negocio}
      </span>
    </a>

    {/* Nav central — uppercase tracking-wide, hover color shift. M5: items del arbol nav; los que
        tienen hijos abren un dropdown CSS-only al hover. Sin hijos -> <a> identico al de hoy (fallback). */}
    {menu.length > 0 && (
      <nav class="hidden lg:flex items-center gap-6" aria-label="Categorias">
        {menu.slice(0, 6).map((item) => (item.children.length > 0 ? (
          <div class="ic-nav-group relative">
            <a
              href={item.href}
              class="ic-nav-trigger text-[13px] font-medium uppercase tracking-[0.06em] text-[var(--ta-color-text-base)]/80 transition-colors duration-200 hover:text-[var(--ta-color-primary)]"
              aria-haspopup="true"
            >
              {item.label}
            </a>
            <div class="ic-nav-dropdown absolute left-0 top-full z-50 pt-3">
              <ul class="min-w-[12rem] rounded-sm border border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)] py-1 shadow-lg">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-[13px] font-medium text-[var(--ta-color-text-base)]/80 transition-colors duration-200 hover:bg-[var(--ta-color-text-base)]/5 hover:text-[var(--ta-color-primary)]"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="text-[13px] font-medium uppercase tracking-[0.06em] text-[var(--ta-color-text-base)]/80 transition-colors duration-200 hover:text-[var(--ta-color-primary)]"
          >
            {item.label}
          </a>
        )))}
      </nav>
    )}

    {/* Iconos derecha */}
    <div class="flex items-center gap-2">
      {mostrarBuscador && <SearchBar template="industrial_clean" />}
      <a
        href="/carrito"
        class="flex items-center gap-2 rounded-sm px-3 py-2 text-sm font-medium text-[var(--ta-color-text-base)] transition-colors duration-200 hover:bg-[var(--ta-color-text-base)]/5"
        aria-label="Carrito"
        data-cart-icon
      >
        <CartBadge />
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="hidden md:inline">Carrito</span>
      </a>
    </div>
  </div>
</header>
