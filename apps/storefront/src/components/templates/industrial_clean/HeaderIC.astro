---
// Industrial Clean · Header · 2026-05-31
// Swiss Modernism 2.0. Logo izq, nav central, search+cart derecha.
// h-16 sticky + backdrop-blur. Border-bottom para separator industrial.
// Nav medium weight, tracking-wide uppercase 13px, hover color shift al primary.

interface Tienda {
  nombre_negocio: string;
  logo_url: string | null;
}
interface Categoria {
  id: string;
  nombre: string;
  slug: string;
  orden: number;
}

import type { MenuItem } from '~/lib/menu';

interface Props {
  tienda: Tienda;
  categorias: Categoria[];
  menu?: MenuItem[];
  mostrarBuscador?: boolean;
}

import SearchBar from '~/components/SearchBar.astro';
import CartBadge from '~/components/CartBadge.astro';
const { tienda, categorias, menu = [], mostrarBuscador } = Astro.props;
---
<style is:global>
  /* M5: dropdown de subcategorias CSS-only (sin JS). is:global -> Astro NO agrega data-astro-cid a los
     elementos del header (canario: tienda sin nav queda byte-identica). Va al TOP para no dejar espacio
     residual tras </header>. Clases ic-nav-* unicas, sin conflicto. focus-within = accesible por teclado;
     pt-3 del panel = puente de hover (no se pierde el grupo al bajar del trigger al dropdown). */
  .ic-nav-dropdown { display: none; }
  .ic-nav-group:hover > .ic-nav-dropdown,
  .ic-nav-group:focus-within > .ic-nav-dropdown { display: block; }
  /* MOBILE.A: drawer del menu (checkbox-hack, sin JS). El checkbox y el panel son hermanos dentro del
     <header>; al tildar (label) se muestra el panel. La navegacion (tap en un link) recarga la pagina
     -> el checkbox nace destildado -> el drawer cierra solo. En desktop SIEMPRE oculto (media query;
     cubre el caso resize-con-drawer-abierto). is:global -> no agrega data-astro-cid (canario desktop). */
  .ic-menu-panel { display: none; }
  .ic-menu-cb:checked ~ .ic-menu-panel { display: block; }
  .ic-menu-acc[open] > summary .ic-menu-chev { transform: rotate(180deg); }
  @media (min-width: 1024px) { .ic-menu-panel { display: none !important; } }
  /* M5.C: tamano de texto del menu. Escala desde el theme (--nav-text-scale en <html>); var ausente =>
     *1 = 13px (identico). Selector de mayor especificidad que .text-[13px] (utility) -> overridea sin
     tocar el HTML de los links. Solo el menu: el carrito (text-sm, fuera del <nav>) no se ve afectado. */
  .ic-nav-menu a,
  .ic-menu-panel a,
  .ic-menu-panel summary { font-size: calc(13px * var(--nav-text-scale, 1)); }
</style>
<header class="sticky top-0 z-40 border-b border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)]/95 backdrop-blur-sm">
  {/* MOBILE.A: checkbox-hack del drawer (hermano del panel; lo toglea el label de abajo). */}
  {menu.length > 0 && <input type="checkbox" id="ic-menu-cb" class="ic-menu-cb" hidden />}
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-6 px-6 lg:px-8">
    {/* MOBILE.A: hamburguesa (solo mobile, lg:hidden). Abre el drawer de abajo. */}
    {menu.length > 0 && (
      <label for="ic-menu-cb" class="ic-menu-btn lg:hidden -ml-1 flex cursor-pointer items-center p-2 text-[var(--ta-color-text-base)]" aria-label="Abrir menu" role="button" tabindex="0">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </label>
    )}
    {/* Logo (img or wordmark) */}
    <a
      href="/"
      class="flex items-center gap-3"
      aria-label={tienda.nombre_negocio}
    >
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt={tienda.nombre_negocio}
          width="36"
          height="36"
          class="h-9 w-9 rounded-sm object-contain"
          loading="eager"
        />
      ) : null}
      <span class="font-display text-base font-semibold text-[var(--ta-color-text-base)]">
        {tienda.nombre_negocio}
      </span>
    </a>

    {/* Nav central — uppercase tracking-wide, hover color shift. M5: items del arbol nav; los que
        tienen hijos abren un dropdown CSS-only al hover. Sin hijos -> <a> identico al de hoy (fallback). */}
    {menu.length > 0 && (
      <nav class="ic-nav-menu hidden lg:flex items-center gap-6" aria-label="Categorias">
        {menu.slice(0, 6).map((item) => (item.children.length > 0 ? (
          <div class="ic-nav-group relative">
            <a
              href={item.href}
              class="ic-nav-trigger text-[13px] font-medium uppercase tracking-[0.06em] text-[var(--ta-color-text-base)]/80 transition-colors duration-200 hover:text-[var(--ta-color-primary)]"
              aria-haspopup="true"
            >
              {item.label}
            </a>
            <div class="ic-nav-dropdown absolute left-0 top-full z-50 pt-3">
              <ul class="min-w-[12rem] rounded-sm border border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)] py-1 shadow-lg">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-[13px] font-medium text-[var(--ta-color-text-base)]/80 transition-colors duration-200 hover:bg-[var(--ta-color-text-base)]/5 hover:text-[var(--ta-color-primary)]"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="text-[13px] font-medium uppercase tracking-[0.06em] text-[var(--ta-color-text-base)]/80 transition-colors duration-200 hover:text-[var(--ta-color-primary)]"
          >
            {item.label}
          </a>
        )))}
      </nav>
    )}

    {/* Iconos derecha */}
    <div class="flex items-center gap-2">
      {mostrarBuscador && <SearchBar template="industrial_clean" />}
      <a
        href="/carrito"
        class="flex items-center gap-2 rounded-sm px-3 py-2 text-sm font-medium text-[var(--ta-color-text-base)] transition-colors duration-200 hover:bg-[var(--ta-color-text-base)]/5"
        aria-label="Carrito"
        data-cart-icon
      >
        <CartBadge />
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <line x1="3" y1="6" x2="21" y2="6" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <span class="hidden md:inline">Carrito</span>
      </a>
    </div>
  </div>

  {/* MOBILE.A: drawer (full-width baja del header). Todos los items del arbol (sin limite, scrollea).
      Hijos -> <details> accordion (summary togglea; el link del padre va como "Ver ..." adentro). */}
  {menu.length > 0 && (
    <div class="ic-menu-panel lg:hidden max-h-[80vh] overflow-y-auto border-t border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)]">
      <nav class="mx-auto max-w-7xl px-4 py-1" aria-label="Menu movil">
        <ul class="divide-y divide-[var(--ta-color-text-base)]/5">
          {menu.map((item) => (
            <li>
              {item.children.length > 0 ? (
                <details class="ic-menu-acc">
                  <summary class="flex cursor-pointer list-none items-center justify-between py-3 text-[13px] font-medium uppercase tracking-[0.06em] text-[var(--ta-color-text-base)]">
                    <span>{item.label}</span>
                    <svg class="ic-menu-chev transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
                  </summary>
                  <ul class="pb-2">
                    <li><a href={item.href} class="block py-2 pl-3 text-[13px] text-[var(--ta-color-text-base)]/70">Ver {item.label}</a></li>
                    {item.children.map((child) => (
                      <li><a href={child.href} class="block py-2 pl-3 text-[13px] text-[var(--ta-color-text-base)]/70">{child.label}</a></li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a href={item.href} class="block py-3 text-[13px] font-medium uppercase tracking-[0.06em] text-[var(--ta-color-text-base)]">{item.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</header>
