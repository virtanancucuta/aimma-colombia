---
// Industrial Clean · Hero · 2026-05-31
// Split 6/6 layout. Eyebrow + H1 + dek + 2 CTAs + trust badges.
// py-20 lg:py-28. NO full-bleed, NO 100vh.

interface Tienda {
  nombre_negocio: string;
  logo_url: string | null;
  ciudad_negocio?: string | null;
}

interface Props {
  tienda: Tienda;
}

const { tienda } = Astro.props;
---

<section class="py-12 lg:py-20">
  <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
    {/* Left col — texto */}
    <div>
      <p class="font-display text-xs uppercase tracking-[0.2em] text-[var(--ta-color-primary)] mb-6">
        Productos y soluciones
      </p>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-tight tracking-tight text-[var(--ta-color-text-base)]">
        {tienda.nombre_negocio}
      </h1>
      <p class="mt-6 font-body text-base lg:text-lg text-[var(--ta-color-text-base)]/70 max-w-xl leading-relaxed">
        Catalogo completo de productos profesionales. Calidad garantizada,
        soporte directo via WhatsApp.
      </p>

      {/* CTAs: primary + ghost outline */}
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href="#productos"
          class="inline-flex items-center gap-2 rounded-sm bg-[var(--ta-color-primary)] px-6 py-3 font-body text-sm font-medium text-[var(--ta-color-on-primary)] transition-colors duration-200 hover:opacity-90"
        >
          Ver productos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
        <a
          href="/legales/contacto"
          class="inline-flex items-center rounded-sm border border-[var(--ta-color-text-base)]/20 px-6 py-3 font-body text-sm font-medium text-[var(--ta-color-text-base)] transition-colors duration-200 hover:bg-[var(--ta-color-text-base)]/5"
        >
          Contactanos
        </a>
      </div>

      {/* Trust strip */}
      <ul class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4 text-xs font-body text-[var(--ta-color-text-base)]/60">
        <li class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          Garantia incluida
        </li>
        <li class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" />
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
            <circle cx="5.5" cy="18.5" r="2.5" />
            <circle cx="18.5" cy="18.5" r="2.5" />
          </svg>
          Envios a toda Colombia
        </li>
        {tienda.ciudad_negocio && (
          <li class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            Sede {tienda.ciudad_negocio}
          </li>
        )}
      </ul>
    </div>

    {/* Right col — image placeholder con grid pattern industrial */}
    <div class="relative aspect-[4/3] overflow-hidden rounded-sm bg-[var(--ta-color-text-base)]/5">
      {tienda.logo_url ? (
        <img
          src={tienda.logo_url}
          alt=""
          class="absolute inset-0 h-full w-full object-contain p-12 opacity-80"
          loading="eager"
        />
      ) : (
        <div class="flex h-full items-center justify-center">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" class="text-[var(--ta-color-primary)]/40" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="0" />
            <line x1="3" y1="9" x2="21" y2="9" />
            <line x1="3" y1="15" x2="21" y2="15" />
            <line x1="9" y1="3" x2="9" y2="21" />
            <line x1="15" y1="3" x2="15" y2="21" />
          </svg>
        </div>
      )}
    </div>
  </div>
</section>
