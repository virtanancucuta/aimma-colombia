---
// Industrial Clean · ProductCard · 2026-05-31
// Technical card. SKU top-left + stock indicator dot top-right. Image bg-base/5.
// Info: nombre semibold + precio mono tabular + "Ver producto →" link.
// bg-white p-5 border. Hover: bg-base/5 (color shift only).

import OptimizedImage from '~/components/OptimizedImage.astro';

interface Props {
  producto: {
    id: string;
    nombre: string;
    slug: string;
    precio: number;
    precio_anterior?: number | null;
    foto_principal?: string | null;
    foto_hover?: string | null;
    stock_disponible?: number | null;
    referencia?: string | null;
  };
  hoverSegundaFoto?: boolean;
  /** Fase 1a: forma del marco (aspect). Default 3/4 para colecciones /c/ y callers no actualizados. */
  forma?: '3/4' | '4/5' | '1/1' | '4/3';
  /** Fase 1a: object-fit. cover = full-bleed (default), contain = entera con margen. */
  fit?: 'cover' | 'contain';
}

const { producto, hoverSegundaFoto = false, forma = '3/4', fit = 'cover' } = Astro.props;
// Fase A: hay 2a foto que mostrar al hover. Gatea el fade-out de la principal (un producto de
// una sola foto NO debe desvanecerse al pasar el mouse).
const mostrarHover = hoverSegundaFoto && !!producto.foto_hover;

// Fase 1a: la forma va al wrapper Y a la img (patron B verificado en navegador: aspect en la img
// da alto definido sin depender de h-full, que ayer desbordaba). Mapa de clases LITERALES (Tailwind
// v4 JIT no genera clases por interpolacion).
const ASPECT: Record<string, string> = { '3/4': 'aspect-[3/4]', '4/5': 'aspect-[4/5]', '1/1': 'aspect-square', '4/3': 'aspect-[4/3]' };
const aspectClass = ASPECT[forma] ?? 'aspect-[3/4]';
// rellenar: object-cover sin padding (full-bleed). contener: object-contain con margen minimo (p-2).
const objectClass = fit === 'contain' ? 'object-contain p-2' : 'object-cover';

const fmt = (n: number) =>
  new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);

const precioStr = fmt(producto.precio);
const precioAnteriorStr = producto.precio_anterior ? fmt(producto.precio_anterior) : null;
const enDescuento = producto.precio_anterior !== null && producto.precio_anterior !== undefined && producto.precio_anterior > producto.precio;
const sinStock = producto.stock_disponible === 0;
const stockLow = producto.stock_disponible !== null && producto.stock_disponible !== undefined && producto.stock_disponible > 0 && producto.stock_disponible <= 5;
---

<article class="group border border-[var(--ta-color-text-base)]/10 bg-[var(--ta-color-bg-base)] transition-colors duration-200 hover:bg-[var(--ta-color-text-base)]/[0.02]">
  <a href={`/p/${producto.slug}`} class="block p-4 lg:p-5" aria-label={producto.nombre}>
    {/* Top meta row: SKU + stock dot */}
    <div class="mb-3 flex items-center justify-between text-[11px] font-body text-[var(--ta-color-text-base)]/50">
      <span class="font-mono uppercase tracking-wide">
        {producto.referencia ? `SKU ${producto.referencia}` : '—'}
      </span>
      <span class="flex items-center gap-1.5" aria-label={sinStock ? 'Agotado' : stockLow ? 'Bajo stock' : 'En stock'}>
        <span
          class:list={[
            'inline-block h-2 w-2 rounded-full',
            sinStock
              ? 'bg-[var(--ta-color-text-base)]/20'
              : stockLow
                ? 'bg-amber-500'
                : 'bg-emerald-600',
          ]}
        ></span>
        {sinStock ? 'Agotado' : stockLow ? 'Bajo stock' : 'En stock'}
      </span>
    </div>

    {/* Image */}
    <div class={`relative ${aspectClass} overflow-hidden bg-[var(--ta-color-text-base)]/5 mb-4`}>
      {producto.foto_principal ? (
        <OptimizedImage
          src={producto.foto_principal}
          alt={producto.nombre}
          width={400}
          height={400}
          loading="lazy"
          class={`absolute inset-0 w-full ${aspectClass} ${objectClass}${mostrarHover ? ' transition-opacity duration-300 group-hover:opacity-0 group-focus-within:opacity-0 motion-reduce:transition-none' : ''}`}
          transitionName={`producto-${producto.id}`}
        />
      ) : (
        <div class="relative flex h-full items-end justify-start p-4">
          <svg class="absolute inset-0 w-full h-full opacity-30" aria-hidden="true">
            <defs>
              <pattern id={`ic-card-grid-${producto.id}`} width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M20 0L0 0 0 20" fill="none" stroke="currentColor" stroke-width="0.4" class="text-[var(--ta-color-text-base)]" />
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill={`url(#ic-card-grid-${producto.id})`} />
          </svg>
          <span class="relative font-display text-[11px] font-medium tabular-nums tracking-wide text-[var(--ta-color-text-base)]/55">
            {producto.referencia ? `REF · ${producto.referencia}` : 'IMAGEN PENDIENTE'}
          </span>
        </div>
      )}

      {/* Fase 1a: segunda foto al hover (CSS-only, decorativa, lazy). MISMO aspect+fit que la
          principal -> crossfade limpio y uniforme. La principal hace fade-out (gateado por
          mostrarHover) para que no asome aunque las 2 fotos difieran de proporcion. */}
      {mostrarHover && (
        <OptimizedImage
          src={producto.foto_hover}
          alt=""
          width={400}
          height={400}
          loading="lazy"
          class={`absolute inset-0 w-full ${aspectClass} ${objectClass} opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-within:opacity-100 motion-reduce:transition-none`}
        />
      )}
    </div>

    {/* Nombre */}
    <h3 class="font-display text-base font-semibold leading-tight text-[var(--ta-color-text-base)] line-clamp-2">
      {producto.nombre}
    </h3>

    {/* Precio mono tabular-nums */}
    <div class="mt-2 flex items-baseline gap-2">
      <span class="font-mono font-medium tabular-nums text-[var(--ta-color-text-base)]">
        {precioStr}
      </span>
      {precioAnteriorStr && enDescuento && (
        <span class="font-mono text-xs tabular-nums text-[var(--ta-color-text-base)]/50 line-through">
          {precioAnteriorStr}
        </span>
      )}
    </div>

    {/* CTA link */}
    <p class="mt-3 inline-flex items-center gap-1 font-body text-xs font-medium text-[var(--ta-color-primary)] group-hover:gap-2 transition-all duration-200">
      Ver producto
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </p>
  </a>
</article>
