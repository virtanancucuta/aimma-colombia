---
// Industrial Clean · ProductDetail (PDP) · Fase F (F1). Swiss limpio: grid 2-col, tipografia sobria.
// Layout per-template; galeria + selector + relacionados son componentes compartidos (estilo por prefix).
import ProductGallery from '~/components/ProductGallery.astro';
import VariantSelector from '~/components/VariantSelector.astro';
import ProductGrid from '~/components/ProductGrid.astro';
import ResenasPDP from '~/components/ResenasPDP.astro';
import { normalizeEditorial } from '~/lib/pdp-editorial';
interface Props { pdp: any }
const { pdp } = Astro.props;
const p = pdp.producto;
// F3: contenido editorial por-producto (guia de tallas + ficha). Bloques solo si hay datos.
const ed = normalizeEditorial(p);
---

<article class="ic-pdp">
  <div class="ic-pdp__top">
    <section class="ic-pdp__gallery" aria-label="Imagenes del producto">
      <ProductGallery pdp={pdp} template="industrial_clean" />
    </section>
    <section class="ic-pdp__info">
      <nav class="ic-pdp__crumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a><span aria-hidden="true"> / </span><span>{p.nombre}</span>
      </nav>
      <h1 class="ic-pdp__title">{p.nombre}</h1>
      {p.referencia && <p class="ic-pdp__sku">Ref: {p.referencia}</p>}
      <VariantSelector pdp={pdp} template="industrial_clean" />{ed.guiaUrl && (
        <details class="ic-pdp__guia">
          <summary class="ic-pdp__guia-sum"><span>Guía de tallas</span><span class="ic-pdp__guia-icon" aria-hidden="true"></span></summary>
          <div class="ic-pdp__guia-body"><img src={ed.guiaUrl} alt="Guía de tallas" class="ic-pdp__guia-img" loading="lazy" /></div>
        </details>
      )}
    </section>
  </div>

  {(p.descripcion || ed.hasFicha) && (
    <section class="ic-pdp__desc">
      <h2 class="ic-pdp__h2">Descripcion</h2>
      {p.descripcion && <p class="ic-pdp__desc-body">{p.descripcion}</p>}{ed.hasFicha && (
        <div class="ic-pdp__ficha">
          {ed.material && (
            <div class="ic-pdp__ficha-row">
              <h3 class="ic-pdp__ficha-label">Material</h3>
              <p class="ic-pdp__ficha-text">{ed.material}</p>
            </div>
          )}
          {ed.ajuste && (
            <div class="ic-pdp__ficha-row">
              <h3 class="ic-pdp__ficha-label">Ajuste</h3>
              <p class="ic-pdp__ficha-text">{ed.ajuste}</p>
            </div>
          )}
          {ed.diseno.length > 0 && (
            <div class="ic-pdp__ficha-row">
              <h3 class="ic-pdp__ficha-label">Diseño</h3>
              <ul class="ic-pdp__ficha-list">{ed.diseno.map((d) => <li>{d}</li>)}</ul>
            </div>
          )}
          {ed.beneficios.length > 0 && (
            <div class="ic-pdp__ficha-row">
              <h3 class="ic-pdp__ficha-label">Beneficios</h3>
              <ul class="ic-pdp__ficha-list">{ed.beneficios.map((d) => <li>{d}</li>)}</ul>
            </div>
          )}
        </div>
      )}
    </section>
  )}

  {pdp.relacionados.length > 0 && (
    <section class="ic-pdp__rel">
      <h2 class="ic-pdp__h2">Tambien te puede interesar</h2>
      <ProductGrid productos={pdp.relacionados} />
    </section>
  )}{pdp.mostrarResenas && <ResenasPDP pdp={pdp} />}
</article>

<style>
  .ic-pdp__top { display: grid; gap: 2rem; }
  @media (min-width: 1024px) { .ic-pdp__top { grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; } }
  .ic-pdp__crumb { font-size: 0.85rem; color: color-mix(in oklab, var(--ta-color-text-base) 60%, transparent); margin-bottom: 0.75rem; }
  .ic-pdp__crumb a:hover { text-decoration: underline; }
  .ic-pdp__title { font-family: var(--ta-font-display); font-size: clamp(1.6rem, 3vw + 0.5rem, 2.25rem); font-weight: 600; letter-spacing: -0.02em; color: var(--ta-color-text-base); line-height: 1.15; }
  .ic-pdp__sku { margin-top: 0.4rem; font-size: 0.8rem; color: color-mix(in oklab, var(--ta-color-text-base) 55%, transparent); font-family: var(--ta-font-body); }
  .ic-pdp__desc { margin-top: 3rem; max-width: 65ch; }
  .ic-pdp__h2 { font-family: var(--ta-font-display); font-size: 1.15rem; font-weight: 600; color: var(--ta-color-text-base); margin-bottom: 0.75rem; }
  .ic-pdp__desc-body { white-space: pre-line; color: color-mix(in oklab, var(--ta-color-text-base) 85%, transparent); font-family: var(--ta-font-body); line-height: 1.6; }
  .ic-pdp__rel { margin-top: 3.5rem; }
  .ic-pdp__rel .ic-pdp__h2 { margin-bottom: 1.25rem; }
  /* F3: guia de tallas (colapsable nativo, no-JS) */
  .ic-pdp__guia { margin-top: 1.5rem; border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 14%, transparent); border-radius: 4px; }
  .ic-pdp__guia-sum { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; padding: 0.7rem 0.9rem; cursor: pointer; font-family: var(--ta-font-body); font-size: 0.9rem; font-weight: 600; color: var(--ta-color-text-base); list-style: none; }
  .ic-pdp__guia-sum::-webkit-details-marker { display: none; }
  .ic-pdp__guia-icon { width: 0.55rem; height: 0.55rem; border-right: 2px solid currentColor; border-bottom: 2px solid currentColor; transform: rotate(45deg); transition: transform 0.2s ease; flex: none; }
  .ic-pdp__guia[open] .ic-pdp__guia-icon { transform: rotate(-135deg); }
  .ic-pdp__guia-body { padding: 0 0.9rem 0.9rem; }
  .ic-pdp__guia-img { width: 100%; height: auto; border-radius: 4px; display: block; }
  /* F3: ficha editorial (sub-bloques bajo la descripcion, continuos) */
  .ic-pdp__ficha { margin-top: 1.5rem; display: grid; gap: 1.1rem; }
  .ic-pdp__ficha-label { font-family: var(--ta-font-display); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: color-mix(in oklab, var(--ta-color-text-base) 60%, transparent); margin-bottom: 0.3rem; }
  .ic-pdp__ficha-text { color: color-mix(in oklab, var(--ta-color-text-base) 85%, transparent); font-family: var(--ta-font-body); line-height: 1.6; white-space: pre-line; }
  .ic-pdp__ficha-list { list-style: none; display: grid; gap: 0.35rem; }
  .ic-pdp__ficha-list li { position: relative; padding-left: 1.1rem; color: color-mix(in oklab, var(--ta-color-text-base) 85%, transparent); font-family: var(--ta-font-body); line-height: 1.5; }
  .ic-pdp__ficha-list li::before { content: ""; position: absolute; left: 0; top: 0.55em; width: 0.35rem; height: 0.35rem; background: color-mix(in oklab, var(--ta-color-text-base) 45%, transparent); border-radius: 50%; }
</style>
