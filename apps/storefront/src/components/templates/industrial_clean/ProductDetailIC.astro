---
// Industrial Clean · ProductDetail (PDP) · Fase F (F1). Swiss limpio: grid 2-col, tipografia sobria.
// Layout per-template; galeria + selector + relacionados son componentes compartidos (estilo por prefix).
import ProductGallery from '~/components/ProductGallery.astro';
import VariantSelector from '~/components/VariantSelector.astro';
import ProductGrid from '~/components/ProductGrid.astro';
interface Props { pdp: any }
const { pdp } = Astro.props;
const p = pdp.producto;
---

<article class="ic-pdp">
  <div class="ic-pdp__top">
    <section class="ic-pdp__gallery" aria-label="Imagenes del producto">
      <ProductGallery pdp={pdp} template="industrial_clean" />
    </section>
    <section class="ic-pdp__info">
      <nav class="ic-pdp__crumb" aria-label="Breadcrumb">
        <a href="/">Inicio</a><span aria-hidden="true"> / </span><span>{p.nombre}</span>
      </nav>
      <h1 class="ic-pdp__title">{p.nombre}</h1>
      {p.referencia && <p class="ic-pdp__sku">Ref: {p.referencia}</p>}
      <VariantSelector pdp={pdp} template="industrial_clean" />
    </section>
  </div>

  {p.descripcion && (
    <section class="ic-pdp__desc">
      <h2 class="ic-pdp__h2">Descripcion</h2>
      <p class="ic-pdp__desc-body">{p.descripcion}</p>
    </section>
  )}

  {pdp.relacionados.length > 0 && (
    <section class="ic-pdp__rel">
      <h2 class="ic-pdp__h2">Tambien te puede interesar</h2>
      <ProductGrid productos={pdp.relacionados} />
    </section>
  )}
</article>

<style>
  .ic-pdp__top { display: grid; gap: 2rem; }
  @media (min-width: 1024px) { .ic-pdp__top { grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; } }
  .ic-pdp__crumb { font-size: 0.85rem; color: color-mix(in oklab, var(--ta-color-text-base) 60%, transparent); margin-bottom: 0.75rem; }
  .ic-pdp__crumb a:hover { text-decoration: underline; }
  .ic-pdp__title { font-family: var(--ta-font-display); font-size: clamp(1.6rem, 3vw + 0.5rem, 2.25rem); font-weight: 600; letter-spacing: -0.02em; color: var(--ta-color-text-base); line-height: 1.15; }
  .ic-pdp__sku { margin-top: 0.4rem; font-size: 0.8rem; color: color-mix(in oklab, var(--ta-color-text-base) 55%, transparent); font-family: var(--ta-font-body); }
  .ic-pdp__desc { margin-top: 3rem; max-width: 65ch; }
  .ic-pdp__h2 { font-family: var(--ta-font-display); font-size: 1.15rem; font-weight: 600; color: var(--ta-color-text-base); margin-bottom: 0.75rem; }
  .ic-pdp__desc-body { white-space: pre-line; color: color-mix(in oklab, var(--ta-color-text-base) 85%, transparent); font-family: var(--ta-font-body); line-height: 1.6; }
  .ic-pdp__rel { margin-top: 3.5rem; }
  .ic-pdp__rel .ic-pdp__h2 { margin-bottom: 1.25rem; }
</style>
