---
// AIMMA Storefront · ProductCard.astro · v2 · 2026-05-31
// Dispatcher product card por plantilla.

import ProductCardFB from '~/components/templates/fashion_bold/ProductCardFB.astro';
import ProductCardIC from '~/components/templates/industrial_clean/ProductCardIC.astro';
import ProductCardMA from '~/components/templates/minimal_artesanal/ProductCardMA.astro';

interface Props {
  producto: {
    id: string;
    nombre: string;
    slug: string;
    precio: number;
    precio_anterior?: number | null;
    foto_principal?: string | null;
    stock_disponible?: number | null;
    referencia?: string | null;
  };
}

const { producto } = Astro.props;
const { tienda } = Astro.locals;
const slug = tienda.plantilla?.slug;
---

{slug === 'fashion_bold' && <ProductCardFB producto={producto} />}
{slug === 'minimal_artesanal' && <ProductCardMA producto={producto} />}
{(slug === 'industrial_clean' || !slug || (slug !== 'fashion_bold' && slug !== 'minimal_artesanal')) && (
  <ProductCardIC producto={producto} />
)}
