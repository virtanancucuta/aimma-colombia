---
// AIMMA Storefront · ProductCard.astro · 2026-05-31
// Card de producto para grids. Imagen + nombre + precio + stock indicator.

import OptimizedImage from '~/components/OptimizedImage.astro';

interface Props {
  producto: {
    id: string;
    nombre: string;
    slug: string;
    precio: number;
    precio_anterior?: number | null;
    foto_principal?: string | null;
    stock_disponible?: number | null;
  };
}

const { producto } = Astro.props;

const precioStr = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: 'COP',
  minimumFractionDigits: 0,
  maximumFractionDigits: 0,
}).format(producto.precio);

const precioAnteriorStr = producto.precio_anterior
  ? new Intl.NumberFormat('es-CO', {
      style: 'currency',
      currency: 'COP',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(producto.precio_anterior)
  : null;

const enDescuento =
  producto.precio_anterior !== null &&
  producto.precio_anterior !== undefined &&
  producto.precio_anterior > producto.precio;

const sinStock = producto.stock_disponible === 0;
---

<article class="group flex flex-col overflow-hidden rounded-lg border bg-white transition hover:shadow-md">
  <a
    href={`/p/${producto.slug}`}
    class="block"
    aria-label={producto.nombre}
  >
    <div class="relative aspect-square overflow-hidden bg-black/5">
      {producto.foto_principal ? (
        <OptimizedImage
          src={producto.foto_principal}
          alt={producto.nombre}
          width={400}
          height={400}
          loading="lazy"
          class="h-full w-full object-cover transition group-hover:scale-105"
          transitionName={`producto-${producto.id}`}
        />
      ) : (
        <div class="flex h-full items-center justify-center text-4xl text-black/20">
          🛍️
        </div>
      )}
      {enDescuento && (
        <span class="absolute left-2 top-2 rounded bg-[var(--ta-color-accent)] px-2 py-1 text-xs font-semibold text-white">
          Oferta
        </span>
      )}
      {sinStock && (
        <span class="absolute right-2 top-2 rounded bg-black/80 px-2 py-1 text-xs font-semibold text-white">
          Agotado
        </span>
      )}
    </div>

    <div class="flex flex-1 flex-col p-4">
      <h3 class="line-clamp-2 text-sm font-medium text-[var(--ta-color-text-base)]">
        {producto.nombre}
      </h3>
      <div class="mt-2 flex items-baseline gap-2">
        <span class="text-lg font-semibold text-[var(--ta-color-text-base)]">
          {precioStr}
        </span>
        {precioAnteriorStr && enDescuento && (
          <span class="text-sm text-[var(--ta-color-text-base)]/50 line-through">
            {precioAnteriorStr}
          </span>
        )}
      </div>
    </div>
  </a>
</article>
