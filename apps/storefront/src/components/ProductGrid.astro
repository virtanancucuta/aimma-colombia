---
// AIMMA Storefront · ProductGrid.astro · v2 · 2026-06-01
// Dispatcher product grid por plantilla. Cada variante tiene layout distinto.

import ProductGridFB from '~/components/templates/fashion_bold/ProductGridFB.astro';
import ProductGridIC from '~/components/templates/industrial_clean/ProductGridIC.astro';
import ProductGridMA from '~/components/templates/minimal_artesanal/ProductGridMA.astro';
import ProductGridEM from '~/components/templates/editorial_magazine/ProductGridEM.astro';

interface Props {
  productos: Array<{
    id: string;
    nombre: string;
    slug: string;
    precio: number;
    precio_anterior?: number | null;
    foto_principal?: string | null;
    stock_disponible?: number | null;
    referencia?: string | null;
  }>;
  emptyMessage?: string;
}

const { productos, emptyMessage } = Astro.props;
const { tienda } = Astro.locals;
const slug = tienda.plantilla?.slug;
---

{slug === 'fashion_bold' && <ProductGridFB productos={productos} emptyMessage={emptyMessage} />}
{slug === 'minimal_artesanal' && <ProductGridMA productos={productos} emptyMessage={emptyMessage} />}
{slug === 'editorial_magazine' && <ProductGridEM productos={productos} emptyMessage={emptyMessage} />}
{(slug === 'industrial_clean' || !slug || !['fashion_bold', 'minimal_artesanal', 'editorial_magazine'].includes(slug)) && (
  <ProductGridIC productos={productos} emptyMessage={emptyMessage} />
)}
