---
// AIMMA Storefront · Footer.astro · v3 · 2026-06-01
// Dispatcher footer — 4 plantillas activas.

import FooterFB from '~/components/templates/fashion_bold/FooterFB.astro';
import FooterIC from '~/components/templates/industrial_clean/FooterIC.astro';
import FooterMA from '~/components/templates/minimal_artesanal/FooterMA.astro';
import FooterEM from '~/components/templates/editorial_magazine/FooterEM.astro';

const { tienda } = Astro.locals;
const slug = tienda.plantilla?.slug;
---

{slug === 'fashion_bold' && <FooterFB tienda={tienda} />}
{slug === 'minimal_artesanal' && <FooterMA tienda={tienda} />}
{slug === 'editorial_magazine' && <FooterEM tienda={tienda} />}
{(slug === 'industrial_clean' || !slug || !['fashion_bold', 'minimal_artesanal', 'editorial_magazine'].includes(slug)) && (
  <FooterIC tienda={tienda} />
)}
