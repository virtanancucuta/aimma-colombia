---
// AIMMA Storefront · SearchBar.astro · Fase B Paso B · buscador del header (patron KAYBU).
// Lupa -> barra expandible full-width (dropdown bajo el header) -> <form method=get action=/buscar>.
// FUNCIONA SIN JS: checkbox-hack (CSS .hsearch__cb:checked ~ .hsearch__panel) abre/cierra y el form GET
// es la base (Enter o boton navega a /buscar?q=). JS minimo de PULIDO: autofocus al abrir, Esc /
// click-fuera / X cierra. Comportamiento UNIFICADO; estilo por plantilla via prefix sobre tokens --ta-*.
// Se renderiza SOLO si el header decide mostrarlo (toggle de Configuracion mostrar_buscador_header).
interface Props { template?: string }
const { template = 'industrial_clean' } = Astro.props;
const prefix = template === 'fashion_bold' ? 'fb'
  : template === 'minimal_artesanal' ? 'ma'
  : template === 'editorial_magazine' ? 'em'
  : 'ic';
---

<div class={`hsearch hsearch--${prefix}`} data-hsearch>
  <input type="checkbox" id="hsearch-cb" class="hsearch__cb" hidden />
  <label for="hsearch-cb" class="hsearch__icon" aria-label="Buscar productos" title="Buscar" role="button" tabindex="0">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </label>
  <div class="hsearch__panel" data-hsearch-panel>
    <form method="get" action="/buscar" role="search" class="hsearch__form">
      <input
        type="search"
        name="q"
        placeholder="Buscar productos..."
        aria-label="Buscar productos"
        maxlength="100"
        autocomplete="off"
        class="hsearch__input"
        data-hsearch-input
      />
      <button type="submit" class="hsearch__submit">Buscar</button>
      <label for="hsearch-cb" class="hsearch__close" aria-label="Cerrar buscador" role="button" tabindex="0">✕</label>
    </form>
  </div>
</div>

<style>
  .hsearch { display: inline-flex; align-items: center; }
  .hsearch__icon {
    display: inline-flex; align-items: center; justify-content: center; cursor: pointer;
    color: var(--ta-color-text-base); padding: 0.4rem; border-radius: 4px; transition: color 0.2s ease, opacity 0.2s ease;
  }
  .hsearch__icon:hover { color: var(--ta-color-primary); }
  /* panel: dropdown absoluto full-width bajo el header (el header es el bloque contenedor: sticky/fixed) */
  .hsearch__panel {
    display: none; position: absolute; left: 0; right: 0; top: 100%; z-index: 50;
    background: var(--ta-color-bg-base);
    border-bottom: 1px solid color-mix(in oklab, var(--ta-color-text-base) 12%, transparent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10);
  }
  .hsearch__cb:checked ~ .hsearch__panel { display: block; }
  .hsearch__form {
    display: flex; align-items: center; gap: 0.75rem;
    max-width: 1100px; margin: 0 auto; padding: 1rem 1.5rem;
  }
  .hsearch__input {
    flex: 1 1 auto; min-width: 0; background: transparent; border: 0;
    border-bottom: 2px solid color-mix(in oklab, var(--ta-color-text-base) 25%, transparent);
    color: var(--ta-color-text-base); font-size: 1.1rem; padding: 0.5rem 0.25rem; outline: none;
  }
  .hsearch__input::placeholder { color: color-mix(in oklab, var(--ta-color-text-base) 50%, transparent); }
  .hsearch__input:focus { border-bottom-color: var(--ta-color-primary); }
  .hsearch__submit {
    flex-shrink: 0; background: var(--ta-color-primary); color: var(--ta-color-bg-base);
    border: 0; border-radius: 6px; padding: 0.6rem 1.1rem; font-weight: 600; cursor: pointer;
    font-family: var(--ta-font-body);
  }
  .hsearch__submit:hover { opacity: 0.9; }
  .hsearch__close {
    flex-shrink: 0; cursor: pointer; color: var(--ta-color-text-base); opacity: 0.55;
    padding: 0.4rem 0.6rem; font-size: 1.15rem; line-height: 1;
  }
  .hsearch__close:hover { opacity: 1; }

  /* ===== acentos por plantilla (estilo nativo de cada header) ===== */
  .hsearch--fb .hsearch__input { font-family: var(--ta-font-display); text-transform: uppercase; letter-spacing: 0.04em; }
  .hsearch--fb .hsearch__submit { border-radius: 0; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.8rem; }
  .hsearch--ma .hsearch__input { font-family: var(--ta-font-display); font-style: italic; }
  .hsearch--ma .hsearch__submit { border-radius: 999px; }
  .hsearch--em .hsearch__input { font-family: var(--ta-font-display); }
  .hsearch--em .hsearch__submit { font-weight: 300; text-transform: uppercase; letter-spacing: 0.1em; }
</style>

<script is:inline>
  (function () {
    var cb = document.getElementById('hsearch-cb');
    if (!cb) return;
    var root = document.querySelector('[data-hsearch]');
    var input = document.querySelector('[data-hsearch-input]');
    // autofocus al abrir (pulido; el checkbox-hack ya abrio el panel via CSS)
    cb.addEventListener('change', function () {
      if (cb.checked && input) { try { input.focus(); } catch (_) {} }
    });
    // Esc cierra
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && cb.checked) cb.checked = false;
    });
    // click fuera del buscador cierra
    document.addEventListener('click', function (e) {
      if (cb.checked && root && !root.contains(e.target)) cb.checked = false;
    });
  })();
</script>
