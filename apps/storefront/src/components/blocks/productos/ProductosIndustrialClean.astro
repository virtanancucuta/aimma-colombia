---
// AIMMA Editor PRO-MAX · Productos · Industrial Clean · SCHEMA v3
// Seccion auto-contenida: lee section.props { categoria_id, limite, orden,
// columnas, mostrar_precio }. Query Supabase via getProductosPorTienda en
// try/catch (empty state si falla). Reusa ProductCardIC de Fase 9.
// Tailwind JIT: clases de columnas LITERALES (mapeadas con ternarios).

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import ProductCard from '~/components/templates/industrial_clean/ProductCardIC.astro';
import { getProductosPorTienda } from '~/lib/catalogo';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'productos' }>).props;

const { tienda, supabase } = Astro.locals;

// try/catch: si Supabase falla, empty state en vez de 500.
let productos: Awaited<ReturnType<typeof getProductosPorTienda>> = [];
try {
  productos = await getProductosPorTienda(supabase, tienda.id, {
    limit: p.limite,
    categoriaId: p.categoria_id ?? undefined,
  });
} catch (err) {
  console.error('[ProductosIC] getProductosPorTienda failed:', err);
  productos = [];
}

// Tailwind JIT requiere strings literales (no template ${}). Mapear con ternarios.
const colsClass = p.columnas === 'auto'
  ? 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4'
  : p.columnas === 2 ? 'grid-cols-2'
  : p.columnas === 3 ? 'grid-cols-2 md:grid-cols-3'
  : p.columnas === 4 ? 'grid-cols-2 md:grid-cols-4'
  : 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4';
---

<SectionShell section={section}>
  {productos.length === 0 ? (
    <div class="ic-empty">Sin productos disponibles</div>
  ) : (
    <div
      class={`grid gap-3 lg:gap-4 ${colsClass}${p.mostrar_precio ? '' : ' ic-productos--sin-precio'}`}
      data-field="productos"
    >
      {productos.map((prod) => <ProductCard producto={prod} />)}
    </div>
  )}
</SectionShell>

<style>
  .ic-empty {
    padding: 3rem;
    text-align: center;
    color: color-mix(in oklab, var(--ta-color-text-base) 60%, transparent);
    font-family: var(--ta-font-body);
    font-size: 0.95rem;
    border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 12%, transparent);
    border-radius: 2px;
  }
  /* mostrar_precio=false: oculta el bloque de precio (div.mt-2 con .items-baseline)
     de ProductCardIC, sin tocar el SKU (.font-mono del meta row superior). */
  .ic-productos--sin-precio :global(.mt-2.items-baseline) { display: none; }
</style>
