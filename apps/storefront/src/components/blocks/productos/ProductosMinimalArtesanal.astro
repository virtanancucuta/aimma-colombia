---
// AIMMA Editor PRO-MAX · Productos · Minimal Artesanal · SCHEMA v3
// Seccion auto-contenida: lee section.props { categoria_id, limite, orden, columnas, mostrar_precio }.
// Query Supabase via getProductosPorTienda (try/catch -> empty state, nunca 500).
// Reusa ProductCardMA. Clases Tailwind LITERALES (JIT). Whitespace editorial generoso.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import ProductCard from '~/components/templates/minimal_artesanal/ProductCardMA.astro';
import { getProductosPorTienda } from '~/lib/catalogo';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'productos' }>).props;
const { tienda, supabase } = Astro.locals;

let productos: Awaited<ReturnType<typeof getProductosPorTienda>> = [];
try {
  productos = await getProductosPorTienda(supabase, tienda.id, {
    limit: p.limite,
    categoriaId: p.categoria_id ?? undefined,
  });
} catch (err) {
  console.error('[ProductosMA] getProductosPorTienda failed:', err);
  productos = [];
}

// Tailwind JIT requiere strings literales (no template ${}).
const colsClass = p.columnas === 'auto'
  ? 'grid-cols-2 lg:grid-cols-3'
  : p.columnas === 2 ? 'grid-cols-2'
  : p.columnas === 3 ? 'grid-cols-2 lg:grid-cols-3'
  : p.columnas === 4 ? 'grid-cols-2 lg:grid-cols-4'
  : 'grid-cols-2 lg:grid-cols-3';
---

<SectionShell section={section}>
  {productos.length === 0 ? (
    <div class="ma-empty">
      <p class="font-display italic">Coleccion en preparacion.</p>
    </div>
  ) : (
    <div class={`ma-grid grid gap-x-8 lg:gap-x-16 gap-y-20 lg:gap-y-28 ${colsClass}`}>
      {productos.map((p2, i) => (
        <div class={`ma-grid-item ${i % 6 === 1 || i % 6 === 4 ? 'lg:translate-y-12' : ''}`}>
          <ProductCard producto={p2} />
        </div>
      ))}
    </div>
  )}
</SectionShell>

<style>
  .ma-empty {
    padding: 6rem 1.5rem;
    text-align: center;
  }
  .ma-empty p {
    color: var(--ta-color-text-base);
    opacity: 0.6;
    font-size: 1.15rem;
    font-variation-settings: 'opsz' 36;
  }
</style>
