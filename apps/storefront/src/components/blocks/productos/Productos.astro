---
// AIMMA Editor PRO-MAX · Productos · UNIFICADO (Fase A.2) · SCHEMA v3
// Un solo renderer para las 4 plantillas. Esqueleto compartido (SectionShell +
// fetch try/catch + empty-check + map). El diff por plantilla va a:
//   (a) ProductCard{IC,FB,MA,EM} (componente de item per-template, reusado tal cual)
//   (b) clase del grid / cols / data-field / wrapper de item / empty (config en frontmatter)
//   (c) los 4 <style> per-template, scopeados+inertes (selectores .ic-/.fb-/.ma-/.em-)
// Salida BYTE-IDENTICA al renderer per-template viejo (validado por test/productos.golden.test.ts).
// Reemplaza Productos{IndustrialClean,FashionBold,MinimalArtesanal,EditorialMagazine}.astro.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import { getProductosPorTienda } from '~/lib/catalogo';
import ProductCardIC from '~/components/templates/industrial_clean/ProductCardIC.astro';
import ProductCardFB from '~/components/templates/fashion_bold/ProductCardFB.astro';
import ProductCardMA from '~/components/templates/minimal_artesanal/ProductCardMA.astro';
import ProductCardEM from '~/components/templates/editorial_magazine/ProductCardEM.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'productos' }>).props;
const { tienda, supabase } = Astro.locals;
const isPreview = Astro.locals?.isPreview;
const plantilla = tienda.plantilla?.slug ?? 'industrial_clean';
// Fase A: toggle por tienda (default ON). Espeja como Header lee mostrar_buscador_header.
const hoverSegundaFoto = (tienda as any).hover_segunda_foto !== false;

// Esqueleto compartido: fetch con try/catch -> empty state, nunca 500.
let productos: Awaited<ReturnType<typeof getProductosPorTienda>> = [];
try {
  productos = await getProductosPorTienda(supabase, tienda.id, {
    limit: p.limite,
    categoriaId: p.categoria_id ?? undefined,
  });
} catch (err) {
  console.error('[Productos] getProductosPorTienda failed:', err);
  productos = [];
}

// cols por plantilla (Tailwind JIT: strings literales). IC/FB usan md+lg; MA/EM solo lg.
function colsFor(plant: string, columnas: typeof p.columnas): string {
  if (plant === 'minimal_artesanal' || plant === 'editorial_magazine') {
    return columnas === 'auto' ? 'grid-cols-2 lg:grid-cols-3'
      : columnas === 2 ? 'grid-cols-2'
      : columnas === 3 ? 'grid-cols-2 lg:grid-cols-3'
      : columnas === 4 ? 'grid-cols-2 lg:grid-cols-4'
      : 'grid-cols-2 lg:grid-cols-3';
  }
  return columnas === 'auto' ? 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4'
    : columnas === 2 ? 'grid-cols-2'
    : columnas === 3 ? 'grid-cols-2 md:grid-cols-3'
    : columnas === 4 ? 'grid-cols-2 md:grid-cols-4'
    : 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4';
}
const colsClass = colsFor(plantilla, p.columnas);

// ProductCard + clase del grid + data-field por plantilla.
let ProductCard: typeof ProductCardIC;
let gridClass: string;
let dataField: string | undefined;
if (plantilla === 'fashion_bold') {
  ProductCard = ProductCardFB;
  const mostrarPrecio = p.mostrar_precio !== false;
  const fbGrid = mostrarPrecio ? 'fb-productos-grid' : 'fb-productos-grid fb-productos-grid--sin-precio';
  gridClass = `${fbGrid} grid gap-x-1 gap-y-12 lg:gap-y-16 ${colsClass}`;
  dataField = undefined;
} else if (plantilla === 'minimal_artesanal') {
  ProductCard = ProductCardMA;
  gridClass = `ma-grid grid gap-x-8 lg:gap-x-16 gap-y-20 lg:gap-y-28 ${colsClass}`;
  dataField = undefined;
} else if (plantilla === 'editorial_magazine') {
  ProductCard = ProductCardEM;
  gridClass = `em-grid grid gap-x-6 lg:gap-x-10 gap-y-16 lg:gap-y-20 ${colsClass}${p.mostrar_precio ? '' : ' em-productos--sin-precio'}`;
  dataField = 'productos';
} else {
  ProductCard = ProductCardIC;
  gridClass = `grid gap-3 lg:gap-4 ${colsClass}${p.mostrar_precio ? '' : ' ic-productos--sin-precio'}`;
  dataField = 'productos';
}
---

<SectionShell section={section}>
  {productos.length === 0 ? (
    plantilla === 'fashion_bold' ? (
      <div class="fb-empty">Sin productos disponibles</div>
    ) : plantilla === 'minimal_artesanal' ? (
      <div class="ma-empty">
        <p class="font-display italic">Coleccion en preparacion.</p>
      </div>
    ) : plantilla === 'editorial_magazine' ? (
      <div class="em-empty">
        <p class="font-display italic text-[var(--ta-color-text-base)]/65" style="font-size:1.25rem;">
          Edicion en curaduria.
        </p>
      </div>
    ) : (
      <div class="ic-empty">Sin productos disponibles</div>
    )
  ) : (
    <div class={gridClass} data-field={isPreview ? dataField : undefined}>
      {productos.map((prod, i) => (
        plantilla === 'minimal_artesanal' ? (
          <div class={`ma-grid-item ${i % 6 === 1 || i % 6 === 4 ? 'lg:translate-y-12' : ''}`}>
            <ProductCard producto={prod} hoverSegundaFoto={hoverSegundaFoto} />
          </div>
        ) : plantilla === 'editorial_magazine' ? (
          <article class="em-grid-item">
            <p class="font-body text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-accent)] font-medium mb-3 tabular-nums">
              Pieza {String(i + 1).padStart(2, '0')}
            </p>
            <ProductCard producto={prod} hoverSegundaFoto={hoverSegundaFoto} />
          </article>
        ) : (
          <ProductCard producto={prod} hoverSegundaFoto={hoverSegundaFoto} />
        )
      ))}
    </div>
  )}
</SectionShell>

<style>
  /* ===== industrial_clean ===== */
  .ic-empty {
    padding: 3rem;
    text-align: center;
    color: color-mix(in oklab, var(--ta-color-text-base) 60%, transparent);
    font-family: var(--ta-font-body);
    font-size: 0.95rem;
    border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 12%, transparent);
    border-radius: 2px;
  }
  /* mostrar_precio=false: oculta el bloque de precio (div.mt-2 con .items-baseline)
     de ProductCardIC, sin tocar el SKU (.font-mono del meta row superior). */
  .ic-productos--sin-precio :global(.mt-2.items-baseline) { display: none; }

  /* ===== fashion_bold ===== */
  /* Fashion Bold productos: hairline divider edge-to-edge entre cards */
  .fb-productos-grid {
    background-color: var(--ta-color-text-base);
  }
  .fb-productos-grid > * {
    background: var(--ta-color-bg-base);
  }
  /* mostrar_precio=false: ocultar el bloque de precio de la ProductCardFB */
  .fb-productos-grid--sin-precio :global(article .pt-4 > div) {
    display: none;
  }
  .fb-empty {
    padding: 3rem;
    text-align: center;
    color: var(--ta-color-text-base);
    opacity: 0.45;
    font-family: var(--ta-font-display);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    border-top: 1px solid var(--ta-color-text-base);
    border-bottom: 1px solid var(--ta-color-text-base);
  }

  /* ===== minimal_artesanal ===== */
  .ma-empty {
    padding: 6rem 1.5rem;
    text-align: center;
  }
  .ma-empty p {
    color: var(--ta-color-text-base);
    opacity: 0.6;
    font-size: 1.15rem;
    font-variation-settings: 'opsz' 36;
  }

  /* ===== editorial_magazine ===== */
  .em-empty {
    padding: 5rem 3rem;
    text-align: center;
    border-top: 1px solid color-mix(in oklab, var(--ta-color-accent) 30%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--ta-color-accent) 30%, transparent);
  }
  /* mostrar_precio=false: oculta el bloque de precio de ProductCardEM
     (el div de la derecha con .text-right), sin tocar el titulo. */
  .em-productos--sin-precio :global(.shrink-0.text-right) { display: none; }
</style>
