---
// AIMMA Editor PRO-MAX · Productos · Editorial Magazine · SCHEMA v3
// Seccion auto-contenida: lee section.props { categoria_id, limite, orden,
// columnas, mostrar_precio }. Query Supabase via getProductosPorTienda en
// try/catch (empty state si falla). Reusa ProductCardEM (Fase 9).
// Lenguaje Vogue/Kinfolk: "Pieza N" eyebrow + rule divider, gaps editoriales.
// Tailwind JIT: clases de columnas LITERALES (mapeadas con ternarios).

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import ProductCard from '~/components/templates/editorial_magazine/ProductCardEM.astro';
import { getProductosPorTienda } from '~/lib/catalogo';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'productos' }>).props;

const { tienda, supabase } = Astro.locals;

// try/catch: si Supabase falla, empty state en vez de 500.
let productos: Awaited<ReturnType<typeof getProductosPorTienda>> = [];
try {
  productos = await getProductosPorTienda(supabase, tienda.id, {
    limit: p.limite,
    categoriaId: p.categoria_id ?? undefined,
  });
} catch (err) {
  console.error('[ProductosEM] getProductosPorTienda failed:', err);
  productos = [];
}

// Tailwind JIT requiere strings literales (no template ${}). Mapear con ternarios.
const colsClass = p.columnas === 'auto'
  ? 'grid-cols-2 lg:grid-cols-3'
  : p.columnas === 2 ? 'grid-cols-2'
  : p.columnas === 3 ? 'grid-cols-2 lg:grid-cols-3'
  : p.columnas === 4 ? 'grid-cols-2 lg:grid-cols-4'
  : 'grid-cols-2 lg:grid-cols-3';
---

<SectionShell section={section}>
  {productos.length === 0 ? (
    <div class="em-empty">
      <p class="font-display italic text-[var(--ta-color-text-base)]/65" style="font-size:1.25rem;">
        Edicion en curaduria.
      </p>
    </div>
  ) : (
    <div
      class={`em-grid grid gap-x-6 lg:gap-x-10 gap-y-16 lg:gap-y-20 ${colsClass}${p.mostrar_precio ? '' : ' em-productos--sin-precio'}`}
      data-field="productos"
    >
      {productos.map((prod, i) => (
        <article class="em-grid-item">
          <p class="font-body text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-accent)] font-medium mb-3 tabular-nums">
            Pieza {String(i + 1).padStart(2, '0')}
          </p>
          <ProductCard producto={prod} />
        </article>
      ))}
    </div>
  )}
</SectionShell>

<style>
  .em-empty {
    padding: 5rem 3rem;
    text-align: center;
    border-top: 1px solid color-mix(in oklab, var(--ta-color-accent) 30%, transparent);
    border-bottom: 1px solid color-mix(in oklab, var(--ta-color-accent) 30%, transparent);
  }
  /* mostrar_precio=false: oculta el bloque de precio de ProductCardEM
     (el div de la derecha con .text-right), sin tocar el titulo. */
  .em-productos--sin-precio :global(.shrink-0.text-right) { display: none; }
</style>
