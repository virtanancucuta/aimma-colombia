---
// AIMMA Editor PRO-MAX · Banner (hero) · Industrial Clean · SCHEMA v3
// Seccion auto-contenida: lee section.props (titulo/subtitulo/boton/imagen_fondo).
// Diseno IBM Plex Sans + precision tipografica, UN solo CTA. data-field para
// edicion inline (Plan 5).

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'banner' }>).props;

const align = p.alineacion ?? 'left';
const alignClass = align === 'center' ? 'text-center mx-auto' : align === 'right' ? 'text-right ml-auto' : 'text-left';
const iconPath: Record<string, string> = {
  arrow: 'M5 12h14M12 5l7 7-7 7',
  whatsapp: '', email: '', phone: '', location: '', link: '',
};
---

<SectionShell section={section}>
  <div class={`ic-banner ${alignClass}`} style="max-width:62ch;">
    <h1
      class="font-display font-semibold text-[var(--ta-color-text-base)] text-balance"
      style="font-size:clamp(2.25rem, 5.5vw, 4.5rem); line-height:1.05; letter-spacing:-0.038em;"
      data-field="titulo"
    >
      {p.titulo}
    </h1>

    {p.subtitulo && (
      <p
        class="mt-6 font-body text-[var(--ta-color-text-base)]/72 leading-[1.6]"
        style="font-size:clamp(1rem, 1.6vw, 1.2rem);"
        data-field="subtitulo"
      >
        {p.subtitulo}
      </p>
    )}

    {p.boton && (
      <a
        href={p.boton.url}
        target={p.boton.target}
        rel={p.boton.target === '_blank' ? 'noopener' : undefined}
        class={`block-button block-button--${p.boton.estilo_visual} mt-9`}
        style="border-radius:2px;"
        data-field="boton.texto"
      >
        {p.boton.texto}
        {(p.boton.icono === 'arrow' || !p.boton.icono) && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d={iconPath.arrow} />
          </svg>
        )}
      </a>
    )}
  </div>
</SectionShell>
