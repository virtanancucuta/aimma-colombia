---
// AIMMA Editor PRO-MAX · CategoriasDestacadas · UNIFICADO · SCHEMA v3 (Lote 3)
// Un solo renderer para las 4 plantillas. Referencia UUIDs de categorias; resuelve
// nombre/slug en tiempo de render via getCategoriasPorIds (tenant-scoped). La imagen es
// PER-ITEM (item.imagen, image-picker), NO la categoria.foto_url. Sin imagen -> tile de marca.
// Empty-guard: publico sin datos -> null (sin SectionShell); preview -> hint seleccionable.
// CERO JavaScript de cliente.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import { getCategoriasPorIds } from '~/lib/catalogo';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'categorias_destacadas' }>).props;
const { tienda, supabase } = Astro.locals;
const isPreview = Astro.locals?.isPreview;
const plantilla = tienda.plantilla?.slug ?? 'industrial_clean';

const prefix = plantilla === 'fashion_bold' ? 'fb'
  : plantilla === 'minimal_artesanal' ? 'ma'
  : plantilla === 'editorial_magazine' ? 'em'
  : 'ic';

let cats: Awaited<ReturnType<typeof getCategoriasPorIds>> = [];
try {
  cats = await getCategoriasPorIds(supabase, tienda.id, p.items.map(i => i.categoria_id));
} catch (err) {
  console.error('[CategoriasDestacadas]', err);
  cats = [];
}

const vacio = cats.length === 0;

// Imagen PER-ITEM (no categoria.foto_url): pareada por categoria_id. Si falta -> tile de marca (fallback simetrico).
const imgById = new Map(p.items.map((i) => [i.categoria_id, i.imagen]));

// Clase de grilla responsive por columnas configuradas
const colsMap: Record<number, string> = { 2: `${prefix}-catdest-grid--2`, 3: `${prefix}-catdest-grid--3`, 4: `${prefix}-catdest-grid--4` };
const gridMod = colsMap[p.columnas] ?? `${prefix}-catdest-grid--3`;
---

{(vacio && !isPreview) ? null : (
  <SectionShell section={section}>
    {vacio ? (
      <div class={`${prefix}-catdest-empty`}>Agregá categorías para destacarlas.</div>
    ) : (
      <>
        {p.titulo && (
          <h2 class={`${prefix}-catdest-title`} data-field={isPreview ? 'titulo' : undefined}>{p.titulo}</h2>
        )}
        <div class={`${prefix}-catdest-grid ${gridMod}`}>
          {cats.map((c) => {
            const img = imgById.get(c.id);
            return (
            <a href={`/c/${c.slug}`} class={`${prefix}-catdest-card`}>
              <div class={`${prefix}-catdest-img-wrap`}>
                {img
                  ? <img class={`${prefix}-catdest-img`} src={img} alt={c.nombre} loading="lazy" />
                  : <div class={`${prefix}-catdest-ph`} aria-hidden="true"></div>
                }
              </div>
              <span class={`${prefix}-catdest-name`}>{c.nombre}</span>
            </a>
            );
          })}
        </div>
      </>
    )}
  </SectionShell>
)}

<style>
  /* ===== industrial_clean =====
     Limpio y técnico: grilla ordenada, imagen cuadrada con borde fino,
     nombre en display semibold, hover sutil con desplazamiento de imagen. */
  .ic-catdest-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 600;
    font-size: clamp(1.25rem, 2vw + 0.75rem, 1.75rem);
    line-height: 1.2;
    text-wrap: balance;
    margin: 0 0 2rem;
  }
  .ic-catdest-grid {
    display: grid;
    gap: 1.25rem;
  }
  .ic-catdest-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .ic-catdest-grid--3 { grid-template-columns: repeat(2, 1fr); }
  .ic-catdest-grid--4 { grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 640px) {
    .ic-catdest-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .ic-catdest-grid--4 { grid-template-columns: repeat(4, 1fr); }
  }
  .ic-catdest-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 10%, transparent);
    background: var(--ta-color-bg-base);
    transition: border-color 0.2s ease;
    overflow: hidden;
  }
  .ic-catdest-card:hover { border-color: color-mix(in oklab, var(--ta-color-text-base) 30%, transparent); }
  .ic-catdest-img-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: color-mix(in oklab, var(--ta-color-text-base) 4%, transparent);
  }
  .ic-catdest-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }
  .ic-catdest-card:hover .ic-catdest-img { transform: scale(1.04); }
  /* fallback sin imagen = tile de MARCA (tokens), no gris. Sin texto encima (nombre va debajo). */
  .ic-catdest-ph {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--ta-color-primary) 16%, var(--ta-color-bg-base)),
      color-mix(in oklab, var(--ta-color-accent) 12%, var(--ta-color-bg-base)));
