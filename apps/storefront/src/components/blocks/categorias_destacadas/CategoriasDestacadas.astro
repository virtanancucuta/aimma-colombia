  .ic-catdest-name {
    display: block;
    padding: 0.75rem 1rem;
    font-family: var(--ta-font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    line-height: 1.3;
    color: var(--ta-color-text-base);
    border-top: 1px solid color-mix(in oklab, var(--ta-color-text-base) 10%, transparent);
    text-overflow: ellipsis;
    overflow: hidden;
