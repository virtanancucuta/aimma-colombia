---
// AIMMA Editor PRO-MAX · Caracteristicas · UNIFICADO (B-secciones Lote 1) · SCHEMA v3
// Un solo renderer para las 4 plantillas. Estructura compartida (SectionShell +
// titulo opcional + grid de cards icono/titulo/texto). El diff por plantilla:
//   (a) prefijo de clase (.ic-/.fb-/.ma-/.em-feat*) -> selecciona el <style> activo
//   (b) los 4 <style> per-template, scopeados e inertes por prefijo
// Iconos: 11 SVG line-icons inline (viewBox 0 0 24 24, stroke currentColor), resueltos
// desde item.icono via ICON_PATHS; fallback a 'check' si el icono no esta en el map.
// data-field gateado por isPreview: en publico NO hay ningun marcador (nodos h2/h3 limpios).

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'caracteristicas' }>).props;
const { tienda } = Astro.locals;
const isPreview = Astro.locals?.isPreview;
const plantilla = tienda.plantilla?.slug ?? 'industrial_clean';

const prefix = plantilla === 'fashion_bold' ? 'fb'
  : plantilla === 'minimal_artesanal' ? 'ma'
  : plantilla === 'editorial_magazine' ? 'em'
  : 'ic';

// Clase de columnas: map estatico (NUNCA clase dinamica interpolada de Tailwind).
const colClass = { 2: 'md:grid-cols-2', 3: 'md:grid-cols-3', 4: 'md:grid-cols-4' }[p.columnas] ?? 'md:grid-cols-3';

// SVG line-icons (solo el contenido interno del <svg>; el wrapper aporta viewBox/stroke).
// Reconocibles y simples; stroke currentColor, viewBox 0 0 24 24.
const ICON_PATHS: Record<string, string> = {
  // camion de envio
  envio: '<path d="M3 6.5h11v9H3z"/><path d="M14 9.5h3.4l2.6 3v3H14z"/><circle cx="7" cy="17.5" r="1.6"/><circle cx="17" cy="17.5" r="1.6"/>',
  // escudo con check (garantia)
  garantia: '<path d="M12 3l7 2.5v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9v-5z"/><path d="M9 12l2 2 4-4"/>',
  // tarjeta de pago
  pago: '<rect x="3" y="6" width="18" height="12" rx="1.5"/><path d="M3 10h18"/><path d="M6.5 14.5h3"/>',
  // medalla / estrella de calidad
  calidad: '<circle cx="12" cy="9" r="5"/><path d="M9 13.2L8 21l4-2.2L16 21l-1-7.8"/><path d="M12 6.6l.9 1.8 2 .3-1.45 1.4.35 2-1.8-.95-1.8.95.35-2L9.1 8.7l2-.3z"/>',
  // auricular de soporte
  soporte: '<path d="M4 13v-1a8 8 0 0116 0v1"/><path d="M4 13a2 2 0 012-2h1v6H6a2 2 0 01-2-2z"/><path d="M20 13a2 2 0 00-2-2h-1v6h1a2 2 0 002-2z"/><path d="M17 17v1a3 3 0 01-3 3h-2"/>',
  // reloj
  reloj: '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 1.8"/>',
  // estrella
  estrella: '<path d="M12 3.5l2.6 5.3 5.9.85-4.25 4.15 1 5.85L12 16.9 6.75 19.6l1-5.85L3.5 9.65l5.9-.85z"/>',
  // check en circulo
  check: '<circle cx="12" cy="12" r="8.5"/><path d="M8.5 12.2l2.4 2.4 4.6-4.8"/>',
  // caja de regalo
  regalo: '<path d="M4 10h16v9H4z"/><path d="M4 10l1-3h14l1 3"/><path d="M12 7v12"/><path d="M12 7c-1.5-2.5-5-2.5-4 0 0 1.2 2 1.2 4 0z"/><path d="M12 7c1.5-2.5 5-2.5 4 0 0 1.2-2 1.2-4 0z"/>',
  // corazon
  corazon: '<path d="M12 20s-7-4.4-7-9.4A3.9 3.9 0 0112 8.2 3.9 3.9 0 0119 10.6c0 5-7 9.4-7 9.4z"/>',
  // flecha en circulo (devoluciones)
  devoluciones: '<path d="M4 8.5A8 8 0 113 12"/><path d="M4 4.5V9h4.5"/>',
};
function iconHtml(icono: string): string {
  return ICON_PATHS[icono] ?? ICON_PATHS.check;
}
---

<SectionShell section={section}>
  {p.titulo && (
    <h2 class={`${prefix}-feat-title`} data-field={isPreview ? 'titulo' : undefined}>{p.titulo}</h2>
  )}
  <div class={`${prefix}-feat-grid grid grid-cols-1 sm:grid-cols-2 ${colClass}`}>
    {p.items.map((item, idx) => (
      <div class={`${prefix}-feat-card`}>
        <span class={`${prefix}-feat-icon`} aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={iconHtml(item.icono)}
          />
        </span>
        <h3 class={`${prefix}-feat-item-title`} data-field={isPreview ? `items.${idx}.titulo` : undefined}>{item.titulo}</h3>
        {item.texto && <p class={`${prefix}-feat-item-text`}>{item.texto}</p>}
      </div>
    ))}
  </div>
</SectionShell>

<style>
  /* ===== industrial_clean =====
     Iconos line, cards con borde sutil + radius 2px, h3 semibold, alineado a la izquierda. */
  .ic-feat-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    text-wrap: balance;
    margin: 0 0 2rem;
  }
  .ic-feat-grid { gap: 1rem; }
  .ic-feat-card {
    border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 10%, transparent);
    border-radius: 2px;
    background: color-mix(in oklab, var(--ta-color-text-base) 3%, transparent);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ic-feat-icon {
    display: inline-flex;
    color: var(--ta-color-accent);
  }
  .ic-feat-icon svg { width: 1.75rem; height: 1.75rem; }
  .ic-feat-item-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.3;
    margin: 0;
  }
  .ic-feat-item-text {
    font-family: var(--ta-font-body);
    color: color-mix(in oklab, var(--ta-color-text-base) 70%, transparent);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0;
  }

  /* ===== fashion_bold =====
     Iconos grandes, sin borde de card, h3 Anton uppercase, contraste fuerte. */
  .fb-feat-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-wrap: balance;
    margin: 0 0 2.5rem;
  }
  .fb-feat-grid { gap: 2.5rem 2rem; }
  .fb-feat-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .fb-feat-icon {
    display: inline-flex;
    color: var(--ta-color-text-base);
  }
  .fb-feat-icon svg { width: 2.75rem; height: 2.75rem; stroke-width: 1.5; }
  .fb-feat-item-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 400;
    text-transform: uppercase;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    line-height: 1.05;
    margin: 0;
  }
  .fb-feat-item-text {
    font-family: var(--ta-font-body);
    color: color-mix(in oklab, var(--ta-color-text-base) 72%, transparent);
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }

  /* ===== minimal_artesanal =====
     Iconos finos, mucho aire, h3 Fraunces, centrado. */
  .ma-feat-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 400;
    font-style: italic;
    font-variation-settings: 'opsz' 48;
    font-size: clamp(1.6rem, 3.2vw, 2.25rem);
    letter-spacing: -0.015em;
    line-height: 1.2;
    text-align: center;
    text-wrap: balance;
    margin: 0 auto 3.5rem;
    max-width: 40ch;
  }
  .ma-feat-grid { gap: 3rem 2.5rem; }
  .ma-feat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }
  .ma-feat-icon {
    display: inline-flex;
    color: var(--ta-color-accent);
  }
  .ma-feat-icon svg { width: 2rem; height: 2rem; stroke-width: 1; }
  .ma-feat-item-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 500;
    font-variation-settings: 'opsz' 24;
    font-size: 1.15rem;
    line-height: 1.25;
    margin: 0;
  }
  .ma-feat-item-text {
    font-family: var(--ta-font-body);
    color: color-mix(in oklab, var(--ta-color-text-base) 65%, transparent);
    font-size: 0.92rem;
    line-height: 1.65;
    max-width: 34ch;
    margin: 0 auto;
  }

  /* ===== editorial_magazine =====
     Icono pequeno + accent line, h3 Fraunces, tono editorial. */
  .em-feat-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 300;
    font-size: clamp(1.6rem, 3.2vw, 2.25rem);
    letter-spacing: -0.012em;
    line-height: 1.15;
    text-wrap: balance;
    margin: 0 0 2.75rem;
  }
  .em-feat-grid { gap: 2.75rem 2.5rem; }
  .em-feat-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding-top: 1.25rem;
    border-top: 1px solid color-mix(in oklab, var(--ta-color-accent) 30%, transparent);
  }
  .em-feat-icon {
    display: inline-flex;
    color: var(--ta-color-accent);
  }
  .em-feat-icon svg { width: 1.4rem; height: 1.4rem; stroke-width: 1.5; }
  .em-feat-item-title {
    font-family: var(--ta-font-display);
    color: var(--ta-color-text-base);
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.25;
    margin: 0;
  }
  .em-feat-item-text {
    font-family: var(--ta-font-body);
    color: color-mix(in oklab, var(--ta-color-text-base) 68%, transparent);
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
  }
</style>
