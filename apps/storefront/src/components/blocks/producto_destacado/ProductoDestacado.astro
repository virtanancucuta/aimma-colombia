---
// AIMMA Editor PRO-MAX · ProductoDestacado · UNIFICADO · SCHEMA v3 (Lote 3)
// Un solo renderer para las 4 plantillas. Referencia un UUID de producto; resuelve
// nombre/precio/foto/slug en tiempo de render via getProductoPorId (tenant-scoped).
// Card grande: imagen destacada + titulo opcional + texto opcional + precio + CTA.
// Empty-guard: publico sin datos -> null (sin SectionShell); preview -> hint seleccionable.
// CERO JavaScript de cliente.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import { getProductoPorId } from '~/lib/catalogo';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'producto_destacado' }>).props;
const { tienda, supabase } = Astro.locals;
const isPreview = Astro.locals?.isPreview;
const plantilla = tienda.plantilla?.slug ?? 'industrial_clean';

const prefix = plantilla === 'fashion_bold' ? 'fb'
  : plantilla === 'minimal_artesanal' ? 'ma'
  : plantilla === 'editorial_magazine' ? 'em'
  : 'ic';

let prod: Awaited<ReturnType<typeof getProductoPorId>> = null;
try {
  prod = await getProductoPorId(supabase, tienda.id, p.producto_id);
} catch (err) {
  console.error('[ProductoDestacado]', err);
  prod = null;
}

const vacio = !prod;

// Formato COP (igual que ProductCardIC)
const fmt = (n: number) =>
  new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);

const precioStr = prod ? fmt(prod.precio) : '';
const precioAnteriorStr = (prod?.precio_anterior != null && prod.precio_anterior > prod.precio)
  ? fmt(prod.precio_anterior)
  : null;
---

{(vacio && !isPreview) ? null : (
  <SectionShell section={section}>
    {vacio ? (
      <div class={`${prefix}-proddest-empty`}>Elegí un producto para destacar.</div>
    ) : (
      <div class={`${prefix}-proddest-wrap`}>
        {/* Imagen */}
        <div class={`${prefix}-proddest-img-wrap`}>
          {prod!.foto_principal
            ? <img class={`${prefix}-proddest-img`} src={prod!.foto_principal} alt={prod!.nombre} loading="lazy" />
            : <div class={`${prefix}-proddest-ph`} aria-hidden="true"></div>
          }
        </div>

        {/* Contenido */}
        <div class={`${prefix}-proddest-content`}>
          {p.titulo && (
            <h2 class={`${prefix}-proddest-title`} data-field={isPreview ? 'titulo' : undefined}>{p.titulo}</h2>
          )}
          <p class={`${prefix}-proddest-nombre`}>{prod!.nombre}</p>

          {/* Precio */}
          <div class={`${prefix}-proddest-precio-wrap`}>
            <span class={`${prefix}-proddest-precio`}>{precioStr}</span>
            {precioAnteriorStr && (
              <span class={`${prefix}-proddest-precio-ant`}>{precioAnteriorStr}</span>
            )}
          </div>

          {/* Texto opcional */}
          {p.texto && (
            <p class={`${prefix}-proddest-texto`} style="white-space:pre-wrap">{p.texto}</p>
          )}

          {/* CTA */}
          <a
            href={`/p/${prod!.slug}`}
            class={`${prefix}-proddest-cta`}
            data-field={isPreview ? 'cta_texto' : undefined}
          >{p.cta_texto || 'Ver producto'}</a>
        </div>
      </div>
    )}
  </SectionShell>
)}

<style>
