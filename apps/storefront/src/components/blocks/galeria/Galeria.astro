---
// AIMMA Editor PRO-MAX · Galeria · UNIFICADO (Fase A.2) · SCHEMA v3
// Un solo renderer para las 4 plantillas. Estructura compartida (SectionShell +
// grid + map de imagenes). El diff por plantilla:
//   (a) clase del grid + data-field (config en frontmatter)
//   (b) editorial_magazine: "Pieza NN" eyebrow + wrapper .em-galeria-frame
//   (c) los 4 <style> per-template, scopeados e inertes por prefijo
// gap tight/normal/loose -> gap-2/4/8 (identico en las 4). layout carrusel/mosaico
// colapsan a grid responsive v1 (los renderers viejos tampoco leen p.layout).
// Salida BYTE-IDENTICA al renderer per-template viejo (validado por test/galeria.golden.test.ts).
// Reemplaza Galeria{IndustrialClean,FashionBold,MinimalArtesanal,EditorialMagazine}.astro.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'galeria' }>).props;
const { tienda } = Astro.locals;
const plantilla = tienda.plantilla?.slug ?? 'industrial_clean';

const prefix = plantilla === 'fashion_bold' ? 'fb'
  : plantilla === 'minimal_artesanal' ? 'ma'
  : plantilla === 'editorial_magazine' ? 'em'
  : 'ic';

// gap (Tailwind JIT: literales). Identico en las 4 plantillas.
const gapClass = p.gap === 'tight' ? 'gap-2'
  : p.gap === 'loose' ? 'gap-8'
  : 'gap-4';

// clase del grid + data-field por plantilla.
let gridClass: string;
let dataField: string | undefined;
if (plantilla === 'fashion_bold') {
  gridClass = `fb-galeria-grid grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 ${gapClass}`;
  dataField = undefined;
} else if (plantilla === 'minimal_artesanal') {
  gridClass = `ma-galeria grid grid-cols-2 md:grid-cols-3 ${gapClass}`;
  dataField = undefined;
} else if (plantilla === 'editorial_magazine') {
  gridClass = `em-galeria-grid grid grid-cols-2 lg:grid-cols-3 ${gapClass}`;
  dataField = undefined;
} else {
  gridClass = `grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 ${gapClass}`;
  dataField = 'imagenes';
}
---

<SectionShell section={section}>
  <div class={gridClass} data-field={dataField}>
    {p.imagenes.map((img, i) => (
      plantilla === 'editorial_magazine' ? (
        <figure class="em-galeria-item group">
          <p class="font-body text-[11px] uppercase tracking-[0.18em] text-[var(--ta-color-accent)] font-medium mb-3 tabular-nums">
            Pieza {String(i + 1).padStart(2, '0')}
          </p>
          <div class="em-galeria-frame">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover"
            />
          </div>
        </figure>
      ) : (
        <figure class={`${prefix}-galeria-item`}>
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
        </figure>
      )
    ))}
  </div>
</SectionShell>

<style>
  /* ===== industrial_clean ===== */
  .ic-galeria-item {
    margin: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 8%, transparent);
    border-radius: 2px;
    background: color-mix(in oklab, var(--ta-color-text-base) 4%, transparent);
  }
  .ic-galeria-item img {
    display: block;
    transition: transform 300ms ease-out;
  }
  .ic-galeria-item:hover img {
    transform: scale(1.04);
  }
  @media (prefers-reduced-motion: reduce) {
    .ic-galeria-item img { transition: none; }
    .ic-galeria-item:hover img { transform: none; }
  }

  /* ===== fashion_bold ===== */
  /* Fashion Bold galeria: aspect 3/4 portrait, NO border, NO radius */
  .fb-galeria-item {
    margin: 0;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 0;
    background: color-mix(in oklab, var(--ta-color-text-base) 6%, transparent);
  }

  /* ===== minimal_artesanal ===== */
  /* Minimal Artesanal galeria: aspect 4/5 portrait editorial, soft radius */
  .ma-galeria-item {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: color-mix(in oklab, var(--ta-color-text-base) 4%, transparent);
  }
  .ma-galeria-item img { display: block; }

  /* ===== editorial_magazine ===== */
  .em-galeria-item { margin: 0; }
  .em-galeria-frame {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: color-mix(in oklab, var(--ta-color-text-base) 4%, transparent);
  }
  .em-galeria-frame img {
    display: block;
    transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .em-galeria-item:hover .em-galeria-frame img { transform: scale(1.04); }
  @media (prefers-reduced-motion: reduce) {
    .em-galeria-frame img { transition: none; }
    .em-galeria-item:hover .em-galeria-frame img { transform: none; }
  }
</style>
