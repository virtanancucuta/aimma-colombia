---
// AIMMA Editor PRO-MAX · Galeria · Minimal Artesanal · SCHEMA v3
// Seccion auto-contenida: lee section.props { imagenes, layout, gap }.
// layout carrusel/mosaico se aplanan a grid responsive v1 (sin carrusel JS aun).
// gap tight/normal/loose -> gap-2 / gap-4 / gap-8. Lenguaje MA: aspect 4/5, soft radius.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'galeria' }>).props;

const gapClass = p.gap === 'tight' ? 'gap-2'
  : p.gap === 'loose' ? 'gap-8'
  : 'gap-4';
---

<SectionShell section={section}>
  <div class={`ma-galeria grid grid-cols-2 md:grid-cols-3 ${gapClass}`}>
    {p.imagenes.map((img) => (
      <figure class="ma-galeria-item">
        <img
          src={img.src}
          alt={img.alt}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </figure>
    ))}
  </div>
</SectionShell>

<style>
  /* Minimal Artesanal galeria: aspect 4/5 portrait editorial, soft radius */
  .ma-galeria-item {
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: color-mix(in oklab, var(--ta-color-text-base) 4%, transparent);
  }
  .ma-galeria-item img { display: block; }
</style>
