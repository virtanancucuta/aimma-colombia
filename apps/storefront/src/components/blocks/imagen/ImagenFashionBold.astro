---
// AIMMA Editor PRO-MAX · Imagen · Fashion Bold · SCHEMA v3
// Seccion auto-contenida: lee section.props { src, alt, objeto, aspect_ratio?, link_url? }.
// Fashion Bold: edge-to-edge, NO border, border-radius 0. Respeta object-fit y aspect_ratio.
// Si hay link_url, envuelve en <a>. loading="lazy".

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'imagen' }>).props;

const objeto = p.objeto ?? 'cover';
const objClass = objeto === 'contain' ? 'object-contain' : 'object-cover';

// aspect_ratio opcional: si no viene, la imagen fluye con su ratio natural.
const ratioStyle = p.aspect_ratio ? `aspect-ratio:${p.aspect_ratio};` : '';
---

<SectionShell section={section}>
  {p.link_url ? (
    <a href={p.link_url} class="fb-imagen-link block">
      <figure class="fb-imagen-figure" style={ratioStyle}>
        <img
          src={p.src}
          alt={p.alt}
          loading="lazy"
          decoding="async"
          class={`fb-imagen-img w-full h-full ${objClass}`}
          data-field="src"
        />
      </figure>
    </a>
  ) : (
    <figure class="fb-imagen-figure" style={ratioStyle}>
      <img
        src={p.src}
        alt={p.alt}
        loading="lazy"
        decoding="async"
        class={`fb-imagen-img w-full h-full ${objClass}`}
        data-field="src"
      />
    </figure>
  )}
</SectionShell>

<style>
  /* Fashion Bold imagen: edge-to-edge, sin borde, sin radius */
  .fb-imagen-figure {
    margin: 0;
    width: 100%;
    overflow: hidden;
    border-radius: 0;
    background: color-mix(in oklab, var(--ta-color-text-base) 6%, transparent);
  }
  .fb-imagen-img {
    display: block;
  }
  .fb-imagen-link {
    text-decoration: none;
  }
</style>
