---
// AIMMA Editor PRO-MAX · Imagen · Minimal Artesanal · SCHEMA v3
// Seccion auto-contenida: lee section.props { src, alt, objeto, aspect_ratio?, link_url? }.
// Respeta object-fit (objeto) y aspect_ratio. Si hay link_url, envuelve en <a>.
// Lenguaje MA: soft border-radius 4px, sin borde duro. loading="lazy".

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'imagen' }>).props;

const objeto = p.objeto ?? 'cover';
const objClass = objeto === 'contain' ? 'object-contain' : 'object-cover';

const ratioStyle = p.aspect_ratio ? `aspect-ratio:${p.aspect_ratio};` : '';
---

<SectionShell section={section}>
  {p.link_url ? (
    <a href={p.link_url} class="ma-imagen-link block">
      <figure class="ma-imagen-figure" style={ratioStyle}>
        <img
          src={p.src}
          alt={p.alt}
          loading="lazy"
          decoding="async"
          class={`ma-imagen-img w-full h-full ${objClass}`}
          data-field="src"
        />
      </figure>
    </a>
  ) : (
    <figure class="ma-imagen-figure" style={ratioStyle}>
      <img
        src={p.src}
        alt={p.alt}
        loading="lazy"
        decoding="async"
        class={`ma-imagen-img w-full h-full ${objClass}`}
        data-field="src"
      />
    </figure>
  )}
</SectionShell>

<style>
  .ma-imagen-figure {
    margin: 0;
    width: 100%;
    overflow: hidden;
    border-radius: 4px;
    background: color-mix(in oklab, var(--ta-color-text-base) 4%, transparent);
  }
  .ma-imagen-img { display: block; }
  .ma-imagen-link { text-decoration: none; }
</style>
