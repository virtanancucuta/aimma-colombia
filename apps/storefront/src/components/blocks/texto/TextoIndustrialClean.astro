---
// AIMMA Editor PRO-MAX · Texto · Industrial Clean · SCHEMA v3
// Seccion auto-contenida: lee section.props { contenido, alineacion, tamanio }.
// Display IBM Plex Sans en tamanios grandes (xl), body Inter en sm/md.
// SIN grid 2D, SIN elementos. data-field="contenido" para edicion inline (Plan 5).

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'texto' }>).props;

const align = p.alineacion ?? 'left';
const tam = p.tamanio ?? 'md';

const alignClass = `block-text--align-${align}`;
const sizeClass = `block-text--size-${tam}`;

// Display (IBM Plex Sans) para titulares (lg/xl); body (Inter) para parrafo (sm/md).
const esDisplay = tam === 'lg' || tam === 'xl';
const fontClass = esDisplay ? 'font-display' : 'font-body';
---

<SectionShell section={section}>
  <div
    class={`ic-texto ${fontClass} ${sizeClass} ${alignClass} text-[var(--ta-color-text-base)]`}
    data-field="contenido"
  >
    {p.contenido}
  </div>
</SectionShell>

<style>
  .ic-texto {
    color: var(--ta-color-text-base);
    white-space: pre-line; /* respeta saltos de linea del contenido */
  }
  .ic-texto.block-text--size-lg,
  .ic-texto.block-text--size-xl {
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.15;
    text-wrap: balance;
  }
  .ic-texto.block-text--size-sm,
  .ic-texto.block-text--size-md {
    line-height: 1.6;
    max-width: 65ch;
  }
  /* En alineacion centrada/derecha, max-width centra el bloque correctamente */
  .ic-texto.block-text--align-center { margin-inline: auto; }
  .ic-texto.block-text--align-right { margin-inline: 0 0 0 auto; }
</style>
