---
// AIMMA Editor PRO-MAX · Texto · Minimal Artesanal · SCHEMA v3
// Seccion auto-contenida: lee section.props { contenido, alineacion, tamanio }.
// Display Fraunces (italic editorial) en lg/xl; body en sm/md. opsz 48/96.
// SIN grid 2D, SIN elementos. data-field="contenido" para edicion inline (Plan 5).

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'texto' }>).props;

const align = p.alineacion ?? 'left';
const tam = p.tamanio ?? 'md';

const alignClass = `block-text--align-${align}`;
const sizeClass = `block-text--size-${tam}`;

const esDisplay = tam === 'lg' || tam === 'xl';
const fontClass = esDisplay ? 'font-display' : 'font-body';
---

<SectionShell section={section}>
  <div
    class={`ma-texto ${fontClass} ${sizeClass} ${alignClass} text-[var(--ta-color-text-base)]`}
    data-field="contenido"
  >
    {p.contenido}
  </div>
</SectionShell>

<style>
  .ma-texto {
    color: var(--ta-color-text-base);
    white-space: pre-line; /* respeta saltos de linea del contenido */
  }
  /* Titulares editoriales Fraunces italic (lg/xl) */
  .ma-texto.block-text--size-lg,
  .ma-texto.block-text--size-xl {
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.018em;
    line-height: 1.18;
    text-wrap: balance;
  }
  .ma-texto.block-text--size-xl { font-variation-settings: 'opsz' 96; }
  .ma-texto.block-text--size-lg { font-variation-settings: 'opsz' 48; }
  /* Cuerpo (sm/md) */
  .ma-texto.block-text--size-sm,
  .ma-texto.block-text--size-md {
    line-height: 1.7;
    max-width: 58ch;
  }
  .ma-texto.block-text--align-center { margin-inline: auto; }
  .ma-texto.block-text--align-right { margin-inline: 0 0 0 auto; }
</style>
