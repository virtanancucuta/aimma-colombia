---
// AIMMA Editor PRO-MAX · Formulario · Minimal Artesanal · SCHEMA v3
// Seccion auto-contenida: lee section.props { titulo?, campos, boton_texto }.
// Submit handler DRY en _FormSubmitHandler.astro: fetch a EF tienda-form-submit
// con honeypot + section_id + tienda_slug. Lenguaje MA: Fraunces italic, pill submit.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import FormSubmitHandler from './_FormSubmitHandler.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'formulario' }>).props;
const tiendaSlug = Astro.locals.tiendaSlug || '';
---

<SectionShell section={section}>
  <form
    class="ma-form-inner"
    novalidate
    data-form-section-id={section.id}
    data-tienda-slug={tiendaSlug}
  >
    {/* Honeypot anti-spam (hidden) */}
    <input
      type="text"
      name="honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
    />

    {p.titulo && (
      <h3 class="ma-form-title" data-field="titulo">{p.titulo}</h3>
    )}

    {p.campos.map((campo, idx) => {
      const fieldId = `${section.id}_field_${idx}`;
      if (campo.tipo_campo === 'textarea') {
        return (
          <div class="ma-form-field">
            <label for={fieldId}>{campo.label}{campo.requerido && <span class="ma-required">*</span>}</label>
            <textarea id={fieldId} name={`field_${idx}`} placeholder={campo.placeholder ?? ''} required={campo.requerido} rows={4}></textarea>
          </div>
        );
      }
      if (campo.tipo_campo === 'select') {
        return (
          <div class="ma-form-field">
            <label for={fieldId}>{campo.label}{campo.requerido && <span class="ma-required">*</span>}</label>
            <select id={fieldId} name={`field_${idx}`} required={campo.requerido}>
              <option value="">{campo.placeholder ?? 'Selecciona...'}</option>
              {(campo.opciones ?? []).map((opt) => <option value={opt}>{opt}</option>)}
            </select>
          </div>
        );
      }
      if (campo.tipo_campo === 'checkbox') {
        return (
          <div class="ma-form-field ma-form-field--check">
            <input id={fieldId} name={`field_${idx}`} type="checkbox" required={campo.requerido} />
            <label for={fieldId}>{campo.label}</label>
          </div>
        );
      }
      return (
        <div class="ma-form-field">
          <label for={fieldId}>{campo.label}{campo.requerido && <span class="ma-required">*</span>}</label>
          <input id={fieldId} name={`field_${idx}`} type={campo.tipo_campo} placeholder={campo.placeholder ?? ''} required={campo.requerido} />
        </div>
      );
    })}

    <button type="submit" class="ma-form-submit">{p.boton_texto}</button>

    <p class="form-message" hidden role="status" aria-live="polite"></p>
  </form>

  <FormSubmitHandler />
</SectionShell>

<style>
  .ma-form-inner {
    max-width: 580px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: var(--ta-font-body);
  }
  .ma-form-title {
    font-family: var(--ta-font-display);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 48;
    letter-spacing: -0.018em;
    font-size: 2rem;
    line-height: 1.18;
    color: var(--ta-color-text-base);
    margin: 0 0 0.5rem 0;
  }
  .ma-form-field { display: flex; flex-direction: column; gap: 0.5rem; }
  .ma-form-field label {
    font-size: 0.8125rem;
    color: var(--ta-color-text-base);
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .ma-required { color: var(--ta-color-accent); margin-left: 4px; }
  .ma-form-field input,
  .ma-form-field textarea,
  .ma-form-field select {
    padding: 0.875rem 1rem;
    border: 1px solid color-mix(in srgb, var(--ta-color-text-base) 15%, transparent);
    border-radius: 4px;
    background: transparent;
    color: var(--ta-color-text-base);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 200ms ease-out;
  }
  .ma-form-field input:focus,
  .ma-form-field textarea:focus,
  .ma-form-field select:focus {
    outline: none;
    border-color: var(--ta-color-accent);
  }
  .ma-form-field--check { flex-direction: row; align-items: center; gap: 0.5rem; }
  .ma-form-field--check input { border: 1px solid var(--ta-color-text-base); padding: 0; height: 18px; width: 18px; border-radius: 2px; }
  .ma-form-submit {
    padding: 0.875rem 2.25rem;
    background: var(--ta-color-text-base);
    color: var(--ta-color-bg-base);
    border: none;
    border-radius: 999px;
    font-family: var(--ta-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 300ms ease-out;
  }
  .ma-form-submit:hover { opacity: 0.85; }
  .form-message {
    margin-top: 1.25rem;
    padding: 0.875rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9375rem;
    font-family: var(--ta-font-body, inherit);
    font-style: italic;
    text-align: center;
  }
  .form-message--success { background: rgba(16,185,129,0.08); color: rgb(6,95,70); }
  .form-message--error   { background: rgba(239,68,68,0.08); color: rgb(127,29,29); }
</style>
