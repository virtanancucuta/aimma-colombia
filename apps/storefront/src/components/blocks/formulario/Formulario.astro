  .em-required { color: var(--ta-color-accent); margin-left: 4px; }
  .em-form-field input,
  .em-form-field textarea,
  .em-form-field select {
    padding: 0.75rem 0;
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--ta-color-text-base) 25%, transparent);
    border-radius: 0;
