  }
  .em-form-field--check { flex-direction: row; align-items: center; gap: 0.5rem; }
  .em-form-field--check input {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    border: 1px solid var(--ta-color-text-base);
    padding: 0;
  }
  .em-form-submit {
    padding: 1rem 2rem;
    background: var(--ta-color-accent);
    color: var(--ta-color-bg-base);
    border: none;
    border-radius: 0;
