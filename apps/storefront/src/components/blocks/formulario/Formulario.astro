    max-width: 580px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: var(--ta-font-body);
  }
  .ma-form-title {
    font-family: var(--ta-font-display);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 48;
