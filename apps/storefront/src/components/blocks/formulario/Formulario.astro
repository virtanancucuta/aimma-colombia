---
// AIMMA Editor PRO-MAX · Formulario · UNIFICADO (Fase A.2) · SCHEMA v3
// Un solo renderer para las 4 plantillas. Estructura compartida (SectionShell +
// form + honeypot + titulo + map de campos + submit + form-message + handler).
// El diff por plantilla:
//   (a) prefijo de clase (.ic-/.fb-/.ma-/.em-form-*) -> selecciona el <style> activo
//   (b) quirks per-template reproducidos FIEL (no se "arreglan", son deuda Fase B):
//       - fashion_bold: fallback boton_texto -> 'Enviar'
//       - minimal_artesanal: <button> sin data-field="boton_texto"
//       - industrial_clean/editorial_magazine: asterisco de requerido en label de checkbox
//   (c) FIX inertness: las reglas .form-message{,--success,--error} eran DESNUDAS y
//       colisionaban al unificar. Se scopean por el padre prefijado .X-form-inner
//       (el <p class="form-message"> NO cambia -> HTML byte-0; el _FormSubmitHandler,
//       que hace msgEl.className='form-message ...', queda intacto).
// Salida HTML BYTE-IDENTICA al per-template viejo (validado por test/formulario.golden.test.ts).
// Reemplaza Formulario{IndustrialClean,FashionBold,MinimalArtesanal,EditorialMagazine}.astro.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import FormSubmitHandler from './_FormSubmitHandler.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'formulario' }>).props;
const { tienda } = Astro.locals;
const plantilla = tienda.plantilla?.slug ?? 'industrial_clean';

const prefix = plantilla === 'fashion_bold' ? 'fb'
  : plantilla === 'minimal_artesanal' ? 'ma'
  : plantilla === 'editorial_magazine' ? 'em'
  : 'ic';

// En prod el middleware SIEMPRE setea locals.tiendaSlug (middleware.ts:49), asi que
// las variantes (?? tienda.slug / || '') de los renderers viejos son equivalentes.
const tiendaSlug = Astro.locals.tiendaSlug ?? Astro.locals.tienda?.slug ?? '';

// fashion_bold: fallback 'Enviar' si boton_texto vacio (reproducido fiel).
const botonTexto = plantilla === 'fashion_bold' ? (p.boton_texto || 'Enviar') : p.boton_texto;

// IC/EM formatean labels multilinea (con whitespace) + asterisco en checkbox; FB/MA
// son compactos (single-line) + checkbox sin asterisco. Se reproduce FIEL por grupo
// (es inconsistencia de formato source pre-existente, visualmente equivalente).
const compactLabels = plantilla === 'fashion_bold' || plantilla === 'minimal_artesanal';
---

<SectionShell section={section}>
  <form
    class={`${prefix}-form-inner`}
    novalidate
    data-form-section-id={section.id}
    data-tienda-slug={tiendaSlug}
  >
    {/* Honeypot anti-spam (oculto fuera de pantalla) */}
    <input
      type="text"
      name="honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
    />

    {p.titulo && (
      <h3 class={`${prefix}-form-title`} data-field="titulo">{p.titulo}</h3>
    )}

    {p.campos.map((campo, idx) => {
      const fieldId = `${section.id}_field_${idx}`;
      const fieldName = `field_${idx}`;

      if (campo.tipo_campo === 'textarea') {
        return (
          <div class={`${prefix}-form-field`}>
            {compactLabels ? (
              <label for={fieldId}>{campo.label}{campo.requerido && <span class={`${prefix}-required`}>*</span>}</label>
            ) : (
              <label for={fieldId}>
                {campo.label}
                {campo.requerido && <span class={`${prefix}-required`}>*</span>}
              </label>
            )}
            <textarea
              id={fieldId}
              name={fieldName}
              placeholder={campo.placeholder ?? ''}
              required={campo.requerido}
              rows={4}
            ></textarea>
          </div>
        );
      }

      if (campo.tipo_campo === 'select') {
        return (
          <div class={`${prefix}-form-field`}>
            {compactLabels ? (
              <label for={fieldId}>{campo.label}{campo.requerido && <span class={`${prefix}-required`}>*</span>}</label>
            ) : (
              <label for={fieldId}>
                {campo.label}
                {campo.requerido && <span class={`${prefix}-required`}>*</span>}
              </label>
            )}
            <select id={fieldId} name={fieldName} required={campo.requerido}>
              <option value="">{campo.placeholder ?? 'Selecciona...'}</option>
              {(campo.opciones ?? []).map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>
        );
      }

      if (campo.tipo_campo === 'checkbox') {
        return (
          <div class={`${prefix}-form-field ${prefix}-form-field--check`}>
            <input id={fieldId} name={fieldName} type="checkbox" required={campo.requerido} />
            {compactLabels ? (
              <label for={fieldId}>{campo.label}</label>
            ) : (
              <label for={fieldId}>
                {campo.label}
                {campo.requerido && <span class={`${prefix}-required`}>*</span>}
              </label>
            )}
          </div>
        );
      }

      // text / email / tel
      return (
        <div class={`${prefix}-form-field`}>
          {compactLabels ? (
            <label for={fieldId}>{campo.label}{campo.requerido && <span class={`${prefix}-required`}>*</span>}</label>
          ) : (
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class={`${prefix}-required`}>*</span>}
            </label>
          )}
          <input
            id={fieldId}
            name={fieldName}
            type={campo.tipo_campo}
            placeholder={campo.placeholder ?? ''}
            required={campo.requerido}
          />
        </div>
      );
    })}

    {plantilla === 'minimal_artesanal' ? (
      <button type="submit" class={`${prefix}-form-submit`}>{botonTexto}</button>
    ) : (
      <button type="submit" class={`${prefix}-form-submit`} data-field="boton_texto">
        {botonTexto}
      </button>
    )}

    <p class="form-message" hidden role="status" aria-live="polite"></p>
  </form>

  <FormSubmitHandler />
</SectionShell>

<style>
  /* ===== industrial_clean ===== */
