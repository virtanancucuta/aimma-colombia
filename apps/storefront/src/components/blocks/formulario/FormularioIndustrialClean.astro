---
// AIMMA Editor PRO-MAX · Formulario · Industrial Clean · SCHEMA v3
// Seccion auto-contenida: lee section.props { titulo?, campos (1..8), boton_texto }.
// Submit via _FormSubmitHandler.astro -> EF tienda-form-submit.
// honeypot oculto + data-form-section-id + data-tienda-slug. Respeta requerido.
// Mapea campos: text/email/tel -> input, textarea -> textarea, select -> select,
// checkbox -> input checkbox.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import FormSubmitHandler from './_FormSubmitHandler.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'formulario' }>).props;

const tiendaSlug = Astro.locals.tiendaSlug ?? Astro.locals.tienda?.slug ?? '';
---

<SectionShell section={section}>
  <form
    class="ic-form-inner"
    novalidate
    data-form-section-id={section.id}
    data-tienda-slug={tiendaSlug}
  >
    {/* Honeypot anti-spam (oculto fuera de pantalla) */}
    <input
      type="text"
      name="honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
    />

    {p.titulo && (
      <h3 class="ic-form-title" data-field="titulo">{p.titulo}</h3>
    )}

    {p.campos.map((campo, idx) => {
      const fieldId = `${section.id}_field_${idx}`;
      const fieldName = `field_${idx}`;

      if (campo.tipo_campo === 'textarea') {
        return (
          <div class="ic-form-field">
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class="ic-required">*</span>}
            </label>
            <textarea
              id={fieldId}
              name={fieldName}
              placeholder={campo.placeholder ?? ''}
              required={campo.requerido}
              rows={4}
            ></textarea>
          </div>
        );
      }

      if (campo.tipo_campo === 'select') {
        return (
          <div class="ic-form-field">
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class="ic-required">*</span>}
            </label>
            <select id={fieldId} name={fieldName} required={campo.requerido}>
              <option value="">{campo.placeholder ?? 'Selecciona...'}</option>
              {(campo.opciones ?? []).map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>
        );
      }

      if (campo.tipo_campo === 'checkbox') {
        return (
          <div class="ic-form-field ic-form-field--check">
            <input id={fieldId} name={fieldName} type="checkbox" required={campo.requerido} />
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class="ic-required">*</span>}
            </label>
          </div>
        );
      }

      // text / email / tel
      return (
        <div class="ic-form-field">
          <label for={fieldId}>
            {campo.label}
            {campo.requerido && <span class="ic-required">*</span>}
          </label>
          <input
            id={fieldId}
            name={fieldName}
            type={campo.tipo_campo}
            placeholder={campo.placeholder ?? ''}
            required={campo.requerido}
          />
        </div>
      );
    })}

    <button type="submit" class="ic-form-submit" data-field="boton_texto">
      {p.boton_texto}
    </button>

    <p class="form-message" hidden role="status" aria-live="polite"></p>
  </form>

  <FormSubmitHandler />
</SectionShell>

<style>
  .ic-form-inner {
    max-width: 580px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-family: var(--ta-font-body);
  }
  .ic-form-title {
    font-family: var(--ta-font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--ta-color-text-base);
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.02em;
  }
  .ic-form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ic-form-field label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ta-color-text-base);
  }
  .ic-required {
    color: #d72c0d;
    margin-left: 4px;
  }
  .ic-form-field input,
  .ic-form-field textarea,
  .ic-form-field select {
    padding: 0.75rem 1rem;
    border: 1px solid color-mix(in oklab, var(--ta-color-text-base) 18%, transparent);
    border-radius: 2px;
    background: var(--ta-color-bg-base);
    color: var(--ta-color-text-base);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 200ms;
  }
  .ic-form-field input:focus,
  .ic-form-field textarea:focus,
  .ic-form-field select:focus {
    outline: none;
    border-color: var(--ta-color-primary);
  }
  .ic-form-field--check {
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
  }
  .ic-form-field--check input {
    width: auto;
    flex: 0 0 auto;
  }
  .ic-form-submit {
    padding: 0.875rem 2rem;
    background: var(--ta-color-primary);
    color: var(--ta-color-on-primary);
    border: none;
    border-radius: 2px;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 200ms;
  }
  .ic-form-submit:hover { opacity: 0.85; }
  .form-message {
    margin-top: 1rem;
    padding: 0.875rem 1.125rem;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
  }
  .form-message--success {
    background: rgba(16, 185, 129, 0.1);
    color: rgb(6, 95, 70);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }
  .form-message--error {
    background: rgba(239, 68, 68, 0.1);
    color: rgb(127, 29, 29);
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
</style>
