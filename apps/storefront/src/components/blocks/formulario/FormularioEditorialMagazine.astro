---
// AIMMA Editor PRO-MAX · Formulario · Editorial Magazine · SCHEMA v3
// Seccion auto-contenida: lee section.props { titulo?, campos (1..8), boton_texto }.
// Submit via _FormSubmitHandler.astro -> EF tienda-form-submit.
// honeypot oculto + data-form-section-id + data-tienda-slug. Respeta requerido.
// Mapea campos: text/email/tel -> input, textarea -> textarea, select -> select,
// checkbox -> input checkbox.
// Lenguaje Vogue/Kinfolk: titulo serif liviano con accent italic, inputs underline.

import type { Section } from '@aimma/database';
import SectionShell from '~/components/blocks/_SectionShell.astro';
import FormSubmitHandler from './_FormSubmitHandler.astro';

interface Props { section: Section; }
const { section } = Astro.props;
const p = (section as Extract<Section, { tipo: 'formulario' }>).props;

const tiendaSlug = Astro.locals.tiendaSlug ?? Astro.locals.tienda?.slug ?? '';
---

<SectionShell section={section}>
  <form
    class="em-form-inner"
    novalidate
    data-form-section-id={section.id}
    data-tienda-slug={tiendaSlug}
  >
    {/* Honeypot anti-spam (oculto fuera de pantalla) */}
    <input
      type="text"
      name="honeypot"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
    />

    {p.titulo && (
      <h3 class="em-form-title" data-field="titulo">{p.titulo}</h3>
    )}

    {p.campos.map((campo, idx) => {
      const fieldId = `${section.id}_field_${idx}`;
      const fieldName = `field_${idx}`;

      if (campo.tipo_campo === 'textarea') {
        return (
          <div class="em-form-field">
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class="em-required">*</span>}
            </label>
            <textarea
              id={fieldId}
              name={fieldName}
              placeholder={campo.placeholder ?? ''}
              required={campo.requerido}
              rows={4}
            ></textarea>
          </div>
        );
      }

      if (campo.tipo_campo === 'select') {
        return (
          <div class="em-form-field">
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class="em-required">*</span>}
            </label>
            <select id={fieldId} name={fieldName} required={campo.requerido}>
              <option value="">{campo.placeholder ?? 'Selecciona...'}</option>
              {(campo.opciones ?? []).map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>
        );
      }

      if (campo.tipo_campo === 'checkbox') {
        return (
          <div class="em-form-field em-form-field--check">
            <input id={fieldId} name={fieldName} type="checkbox" required={campo.requerido} />
            <label for={fieldId}>
              {campo.label}
              {campo.requerido && <span class="em-required">*</span>}
            </label>
          </div>
        );
      }

      // text / email / tel
      return (
        <div class="em-form-field">
          <label for={fieldId}>
            {campo.label}
            {campo.requerido && <span class="em-required">*</span>}
          </label>
          <input
            id={fieldId}
            name={fieldName}
            type={campo.tipo_campo}
            placeholder={campo.placeholder ?? ''}
            required={campo.requerido}
          />
        </div>
      );
    })}

    <button type="submit" class="em-form-submit" data-field="boton_texto">
      {p.boton_texto}
    </button>

    <p class="form-message" hidden role="status" aria-live="polite"></p>
  </form>

  <FormSubmitHandler />
</SectionShell>

<style>
  .em-form-inner {
    max-width: 580px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: var(--ta-font-body);
  }
  .em-form-title {
    font-family: var(--ta-font-display);
    font-weight: 300;
    letter-spacing: -0.012em;
    font-size: 2.25rem;
    line-height: 1.05;
    color: var(--ta-color-text-base);
    margin: 0 0 0.5rem 0;
  }
  .em-form-title :global(span),
  .em-form-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--ta-color-accent);
  }
  .em-form-field { display: flex; flex-direction: column; gap: 0.5rem; }
  .em-form-field label {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--ta-color-text-base);
    font-weight: 500;
    font-family: var(--ta-font-body);
  }
  .em-required { color: var(--ta-color-accent); margin-left: 4px; }
  .em-form-field input,
  .em-form-field textarea,
  .em-form-field select {
    padding: 0.75rem 0;
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--ta-color-text-base) 25%, transparent);
    border-radius: 0;
    background: transparent;
    color: var(--ta-color-text-base);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 200ms;
  }
  .em-form-field input:focus,
  .em-form-field textarea:focus,
  .em-form-field select:focus {
    outline: none;
    border-bottom-color: var(--ta-color-accent);
  }
  .em-form-field--check { flex-direction: row; align-items: center; gap: 0.5rem; }
  .em-form-field--check input {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    border: 1px solid var(--ta-color-text-base);
    padding: 0;
  }
  .em-form-submit {
    padding: 1rem 2rem;
    background: var(--ta-color-accent);
    color: var(--ta-color-bg-base);
    border: none;
    border-radius: 0;
    font-family: var(--ta-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 200ms;
  }
  .em-form-submit:hover { opacity: 0.88; }
  .form-message {
    margin-top: 1rem;
    padding: 0.875rem 1.25rem;
    border-radius: 0;
    font-size: 0.9375rem;
    font-family: var(--ta-font-display, inherit);
    font-weight: 300;
    border-left: 2px solid currentColor;
  }
  .form-message--success { color: rgb(6,95,70); background: rgba(16,185,129,0.05); }
  .form-message--error   { color: rgb(127,29,29); background: rgba(239,68,68,0.05); }
</style>
