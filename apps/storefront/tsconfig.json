{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@aimma/database": ["../../packages/database/src/index.ts"],
      "@aimma/database/*": ["../../packages/database/src/*"]
    },
    "jsx": "preserve",
    "verbatimModuleSyntax": true
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules"]
}
